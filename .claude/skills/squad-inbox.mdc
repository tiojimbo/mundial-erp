5. **notification-response.dto.ts**
   ```typescript
   export class NotificationResponseDto {
     @ApiProperty() id: string;
     @ApiProperty() userId: string;
     @ApiProperty() type: string;
     @ApiProperty() category: string;
     @ApiProperty() title: string;
     @ApiProperty() description: string;
     @ApiPropertyOptional() entityId: string | null;
     @ApiPropertyOptional() entityUrl: string | null;
     @ApiProperty() status: string;
     @ApiPropertyOptional() snoozedUntil: string | null;
     @ApiProperty() createdAt: string;
     @ApiPropertyOptional() readAt: string | null;
     @ApiPropertyOptional() clearedAt: string | null;

     static fromEntity(entity: Notification): NotificationResponseDto {
       const dto = new NotificationResponseDto();
       Object.assign(dto, {
         id: entity.id,
         userId: entity.userId,
         type: entity.type.toLowerCase().replace('_', '.'),  // TASK_OVERDUE → task.overdue
         category: entity.category.toLowerCase(),             // PRIMARY → primary
         title: entity.title,
         description: entity.description,
         entityId: entity.entityId,
         entityUrl: entity.entityUrl,
         status: entity.status.toLowerCase(),                 // UNREAD → unread
         snoozedUntil: entity.snoozedUntil?.toISOString() ?? null,
         createdAt: entity.createdAt.toISOString(),
         readAt: entity.readAt?.toISOString() ?? null,
         clearedAt: entity.clearedAt?.toISOString() ?? null,
       });
       return dto;
     }
   }
   ```

   **IMPORTANTE:** O `fromEntity` converte enums Prisma (UPPER_SNAKE) para formato frontend (lowercase dot-notation) conforme INBOX_SPEC secao 3. Mapeamento:
   - `TASK_OVERDUE` → `task.overdue`
   - `TASK_DUE_SOON` → `task.due_soon`
   - `MESSAGE` → `message`
   - `MENTION` → `mention`
   - `SYSTEM` → `system`
   - `PRIMARY` → `primary`, `OTHER` → `other`
   - `UNREAD` → `unread`, `READ` → `read`, `CLEARED` → `cleared`, `SNOOZED` → `snoozed`

