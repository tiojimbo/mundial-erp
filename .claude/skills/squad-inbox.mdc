### Especificacao funcional

1. **date.ts** — Implementa EXATAMENTE o contrato da secao "Contratos Compartilhados" (Date Helpers)
   ```typescript
   import { isToday, isYesterday, differenceInDays, format } from 'date-fns'
   import { ptBR } from 'date-fns/locale'

   export type DateGroup = 'today' | 'yesterday' | 'last7days' | 'last30days' | 'older'

   export function groupNotificationsByDate(items: Notification[]): Map<DateGroup, Notification[]> {
     const groups = new Map<DateGroup, Notification[]>()
     for (const item of items) {
       const date = new Date(item.createdAt)
       let group: DateGroup
       if (isToday(date)) group = 'today'
       else if (isYesterday(date)) group = 'yesterday'
       else if (differenceInDays(new Date(), date) <= 7) group = 'last7days'
       else if (differenceInDays(new Date(), date) <= 30) group = 'last30days'
       else group = 'older'
       if (!groups.has(group)) groups.set(group, [])
       groups.get(group)!.push(item)
     }
     return groups
   }

   export function getGroupLabel(group: DateGroup): string {
     const labels: Record<DateGroup, string> = {
       today: 'Today',
       yesterday: 'Yesterday',
       last7days: 'Last 7 days',
       last30days: 'Last 30 days',
       older: 'Older',
     }
     return labels[group]
   }

   export function formatNotificationTime(dateStr: string): string {
     const date = new Date(dateStr)
     if (isToday(date)) return format(date, 'HH:mm')
     if (date.getFullYear() === new Date().getFullYear()) {
       return format(date, "d 'de' MMM", { locale: ptBR })
     }
     return format(date, "d 'de' MMM 'de' yyyy", { locale: ptBR })
   }
   ```

