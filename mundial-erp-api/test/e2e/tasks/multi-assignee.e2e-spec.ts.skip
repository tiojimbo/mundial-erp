/**
 * E2E scaffold — Multi-assignee PATCH + Prisma extension (ADR-001).
 *
 * Status: placeholder. Habilitar em Sprint 2 apos:
 *   - AssigneesSyncService (Patricia) estavel.
 *   - Prisma extension primary-assignee-cache integrada no PrismaService
 *     (ja verificada no spec prisma-extension.spec).
 *
 * Diferenca vs prisma-extension.spec: aqui testamos o PATCH /tasks/:id que
 * recebe `assignees: { add: [ids], remove: [ids] }` em transacao unica.
 * Prisma-extension.spec testa a extensao isolada. Ambos cobrem ADR-001 de
 * angulos complementares.
 *
 * Cobertura (PLANO-TASKS §4.4 + §8.6 + ADR-001):
 *   - PATCH em transacao unica aplica add + remove atomicamente.
 *   - Extension dispara apos commit e atualiza primaryAssigneeCache.
 *   - Remover UNICO assignee → primaryAssigneeCache=NULL.
 *   - Remover primary com outros restantes → promove mais antigo (createdAt
 *     asc, tie-break por sortOrder) como novo primary.
 */

import { Test, TestingModule } from '@nestjs/testing';
import { INestApplication, ValidationPipe } from '@nestjs/common';
import type { App } from 'supertest/types';
import { AppModule } from '../../../src/app.module';
import {
  cleanupWorkspace,
  createTestProcess,
  createTestTask,
  createTestUser,
  createTestWorkspace,
  TestProcess,
  TestUser,
  TestWorkspace,
} from './setup';

describe.skip('Tasks multi-assignee + Prisma extension (e2e) — Sprint 2 ativar', () => {
  let app: INestApplication<App>;
  let ws: TestWorkspace;
  let processCtx: TestProcess;
  let taskId: string;
  let userA: TestUser;
  let userB: TestUser;
  let userC: TestUser;

  beforeAll(async () => {
    const moduleFixture: TestingModule = await Test.createTestingModule({
      imports: [AppModule],
    }).compile();

    app = moduleFixture.createNestApplication();
    app.setGlobalPrefix('api/v1', {
      exclude: ['health', 'health/ready', 'docs'],
    });
    app.useGlobalPipes(
      new ValidationPipe({
        whitelist: true,
        forbidNonWhitelisted: true,
        transform: true,
        transformOptions: { enableImplicitConversion: true },
      }),
    );
    await app.init();

    ws = await createTestWorkspace(app);
    processCtx = await createTestProcess(app, ws.workspaceId);
    taskId = (await createTestTask(app, processCtx, ws.ownerUserId)).taskId;
    userA = await createTestUser(app, ws.workspaceId, 'OPERATOR');
    userB = await createTestUser(app, ws.workspaceId, 'OPERATOR');
    userC = await createTestUser(app, ws.workspaceId, 'OPERATOR');
  }, 60_000);

  afterAll(async () => {
    if (!app) return;
    await cleanupWorkspace(app, ws.workspaceId);
    await app.close();
  });

  // Story ASGN-01 — atomic patch
  it.skip('PATCH /tasks/:id com assignees:{add,remove} aplica tudo em transacao unica', async () => {
    expect(userA).toBeDefined();
    expect(userB).toBeDefined();
  });

  // Story ASGN-02 — extension reacao
  it.skip('extension atualiza primaryAssigneeCache automaticamente apos add (ADR-001)', async () => {
    expect(taskId).toBeTruthy();
  });

  // Story ASGN-03 — null quando zero assignees
  it.skip('remover unico assignee deixa primaryAssigneeCache = NULL', async () => {
    expect(true).toBe(true);
  });

  // Story ASGN-04 — promocao automatica
  it.skip('remover primary com restantes promove mais antigo (createdAt asc) como novo primary', async () => {
    expect(userC).toBeDefined();
  });
});
