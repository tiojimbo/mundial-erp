/**
 * E2E scaffold — Task Tags (nameLower normalization + attach/detach).
 *
 * Status: placeholder. Habilitar em Sprint 2 apos modulo task-tags estavel.
 *
 * Cobertura planejada (PLANO-TASKS §8.2):
 *   - POST /task-tags { name: "Frontend" } normaliza para nameLower
 *     "frontend" e grava ambas colunas.
 *   - Unique (workspaceId, nameLower) retorna 409 Conflict se ja existe,
 *     com body.data.existingTag populado (resolucao client-side sem loop).
 *   - POST /tasks/:id/tags attach enfileira outbox TAG_ADDED. DELETE attach
 *     enfileira TAG_REMOVED.
 *   - Cross-tenant: tag de wsA nao visivel em wsB (GET → []); attach via
 *     tagId de wsA em task de wsB → 404.
 */

import { Test, TestingModule } from '@nestjs/testing';
import { INestApplication, ValidationPipe } from '@nestjs/common';
import request from 'supertest';
import type { App } from 'supertest/types';
import { AppModule } from '../../../src/app.module';
import {
  cleanupWorkspace,
  createTestProcess,
  createTestTask,
  createTestWorkspace,
  TestProcess,
  TestWorkspace,
} from './setup';

describe.skip('Task Tags (e2e) — Sprint 2 ativar', () => {
  let app: INestApplication<App>;
  let wsA: TestWorkspace;
  let wsB: TestWorkspace;
  let processA: TestProcess;
  let taskAId: string;

  beforeAll(async () => {
    const moduleFixture: TestingModule = await Test.createTestingModule({
      imports: [AppModule],
    }).compile();

    app = moduleFixture.createNestApplication();
    app.setGlobalPrefix('api/v1', {
      exclude: ['health', 'health/ready', 'docs'],
    });
    app.useGlobalPipes(
      new ValidationPipe({
        whitelist: true,
        forbidNonWhitelisted: true,
        transform: true,
        transformOptions: { enableImplicitConversion: true },
      }),
    );
    await app.init();

    wsA = await createTestWorkspace(app);
    wsB = await createTestWorkspace(app);
    processA = await createTestProcess(app, wsA.workspaceId);
    taskAId = (await createTestTask(app, processA, wsA.ownerUserId)).taskId;
  }, 60_000);

  afterAll(async () => {
    if (!app) return;
    await cleanupWorkspace(app, wsA.workspaceId);
    await cleanupWorkspace(app, wsB.workspaceId);
    await app.close();
  });

  // Story TAG-01 — normalization
  it.skip('POST normaliza nameLower (Frontend → frontend) e grava ambas colunas', async () => {
    const res = await request(app.getHttpServer())
      .post('/api/v1/task-tags')
      .set('Authorization', `Bearer ${wsA.token}`)
      .send({ name: 'Frontend', color: '#3b82f6' });
    expect(res.status).toBe(201);
    expect(res.body.data.name).toBe('Frontend');
    expect(res.body.data.nameLower).toBe('frontend');
  });

  // Story TAG-02 — unique conflict
  it.skip('unique (workspaceId, nameLower) retorna 409 com existingTag no body', async () => {
    expect(true).toBe(true);
  });

  // Story TAG-03 — outbox events
  it.skip('POST /tasks/:id/tags enfileira outbox TAG_ADDED', async () => {
    expect(taskAId).toBeTruthy();
  });

  it.skip('DELETE /tasks/:id/tags/:tagId enfileira outbox TAG_REMOVED', async () => {
    expect(true).toBe(true);
  });

  // Story TAG-04 — cross-tenant
  it.skip('GET /task-tags em wsB nao retorna tags de wsA', async () => {
    expect(wsB).toBeDefined();
  });

  it.skip('attach de tag de wsA em task de wsB retorna 404', async () => {
    expect(true).toBe(true);
  });
});
