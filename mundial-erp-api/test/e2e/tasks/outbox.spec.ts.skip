/**
 * E2E scaffold — Outbox pattern (ADR-003).
 *
 * Status: placeholder. Habilitar em Sprint 1 (foundations) quando tabela
 * `task_outbox_events` + worker BullMQ `task-outbox-worker` estiverem em
 * staging. Sem worker ativo, as asserts de processamento ficam falso-OK.
 *
 * Cobertura planejada (PLANO-TASKS §8.11, ADR-003, §16 risco R2):
 *   - Evento STATUS_CHANGED enfileirado e processado em ate 5s (SLI p95).
 *   - DLQ apos 3 tentativas de retry com backoff exponencial.
 *   - Idempotencia: mesmo (aggregateId, eventType, hash) nao duplica efeito.
 */

import { Test, TestingModule } from '@nestjs/testing';
import { INestApplication, ValidationPipe } from '@nestjs/common';
import type { App } from 'supertest/types';
import { AppModule } from '../../../src/app.module';
import {
  cleanupWorkspace,
  createTestProcess,
  createTestTask,
  createTestWorkspace,
  TestProcess,
  TestWorkspace,
} from './setup';

describe.skip('Tasks outbox pattern (e2e) — Sprint 1 ativar', () => {
  let app: INestApplication<App>;
  let ws: TestWorkspace;
  let processCtx: TestProcess;
  let taskId: string;

  beforeAll(async () => {
    const moduleFixture: TestingModule = await Test.createTestingModule({
      imports: [AppModule],
    }).compile();

    app = moduleFixture.createNestApplication();
    app.setGlobalPrefix('api/v1', {
      exclude: ['health', 'health/ready', 'docs'],
    });
    app.useGlobalPipes(
      new ValidationPipe({
        whitelist: true,
        forbidNonWhitelisted: true,
        transform: true,
        transformOptions: { enableImplicitConversion: true },
      }),
    );
    await app.init();

    ws = await createTestWorkspace(app);
    processCtx = await createTestProcess(app, ws.workspaceId);
    taskId = (await createTestTask(app, processCtx, ws.ownerUserId)).taskId;
  }, 60_000);

  afterAll(async () => {
    if (!app) return;
    await cleanupWorkspace(app, ws.workspaceId);
    await app.close();
  });

  // Story TS-S1-04 — SLI `task_outbox_lag_seconds` p95 < 5s
  it.skip('evento STATUS_CHANGED enfileirado e processado em ate 5s', async () => {
    expect(taskId).toBeTruthy();
    // POST /tasks/:id/status -> assert WorkItemStatusHistory row criado < 5s
  });

  // Story TS-S1-05 — PLANO-TASKS §8.11
  it.skip('evento move para DLQ apos 3 falhas com backoff exponencial (1s, 2s, 4s)', async () => {
    expect(true).toBe(true);
  });

  // Story TS-S1-06 — idempotencia (PLANO-TASKS §8.11)
  it.skip('evento idempotente: mesmo aggregateId + eventType + hash nao duplica efeito', async () => {
    expect(true).toBe(true);
  });
});
