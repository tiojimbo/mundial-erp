  TASK_DUE_SOON
  MESSAGE
  MENTION
  SYSTEM
}

enum NotificationStatus {
  UNREAD
  READ
  CLEARED
  SNOOZED
}

enum NotificationCategory {
  PRIMARY
  OTHER
}

// --- Chat ---

enum ChannelType {
  PUBLIC
  PRIVATE
  DIRECT
  GROUP_DM
}

enum ChatMessageType {
  MESSAGE
  POST
}

enum ContentFormat {
  TEXT_MD
  TEXT_PLAIN
}

enum ChannelMemberRole {
  OWNER
  ADMIN
  MEMBER
}

// --- Workspace (Multi-tenancy) ---

enum WorkspaceMemberRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum WorkspacePlan {
  FREE
  PRO
  ENTERPRISE
}

enum InviteStatus {
