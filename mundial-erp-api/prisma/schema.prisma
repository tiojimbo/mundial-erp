}

// Operacional — update-in-place; sem deletedAt.
model KommoSyncCheckpoint {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  entity      String
  lastCursor  String?  @map("last_cursor")
  lastSyncAt  DateTime @default(now()) @map("last_sync_at")
  entityCount Int      @default(0) @map("entity_count")
  lastError   String?  @map("last_error")

  @@unique([workspaceId, entity])
  @@index([workspaceId, lastSyncAt])
  @@map("kommo_sync_checkpoints")
}

// Operacional — hard delete via purge cron; sem deletedAt.
// Ver ADR-009 (kommo-metric-snapshot) para contrato de metricKeys.
model KommoMetricSnapshot {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  pipelineId  String?   @map("pipeline_id") // null = agregado todos pipelines
  metricKey   String    @map("metric_key") // "open_conversations", "total_resolved", ...
  windowStart DateTime? @map("window_start")
  windowEnd   DateTime? @map("window_end")
  value       BigInt
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([workspaceId, pipelineId, metricKey, windowStart, windowEnd])
  @@index([workspaceId, metricKey, updatedAt])
  @@map("kommo_metric_snapshots")
}

// ============================================================================
// Task Types Templates — M1 Custom Fields (Migration custom_fields, TTT-010)
// ----------------------------------------------------------------------------
// Modulo autonomo (PLANO-TASK-TYPES-TEMPLATES.md §"Modelo de Dados → M1").
// Permite que workspaces (ou builtins globais com workspaceId NULL) definam
// campos personalizados tipados (TEXT/NUMBER/CURRENCY/DATE/DROPDOWN/CPF/CNPJ/
// URL/EMAIL/PHONE) e armazenem valores associados a WorkItems. Funciona
// independente de TaskTypeTemplate (M2) — qualquer task pode ter custom fields.
// Aditivo: zero ALTER em tabelas existentes alem de relacao reversa em
// WorkItem e Workspace.
// ============================================================================

enum CustomFieldType {
  CHECKBOX
  CNPJ
  CPF
  CURRENCY
  DATE
  DROPDOWN
  DURATION
  EMAIL
  LABEL
  NUMBER
  PEOPLE
  PERCENTAGE
  PHONE
  QUANTITY
  RATING
  RELATIONSHIP
  ROLLUP
  SELECT
  TEAM
  TEXT
  URL
  USER
}

/// CustomFieldDefinition — definicao reutilizavel de um campo personalizado.
/// workspaceId NULL = builtin global (visivel a todos). Builtins seedados
/// possuem isBuiltin=true e nao sao deletaveis via API.
/// Soft delete preserva valores existentes (orfaos invisiveis na UI).
model CustomFieldDefinition {
  id               String          @id @default(cuid())
  workspaceId      String?         @map("workspace_id")
  spaceId          String?         @map("space_id")
  folderId         String?         @map("folder_id")
  listId           String?         @map("list_id")
  customTaskTypeId String?         @map("custom_task_type_id")
  key              String
  name             String
  label            String
  description      String?
  type             CustomFieldType
  required         Boolean         @default(false)
  options          Json            @default("[]")
  config           Json?
  defaultValue     Json?           @map("default_value")
  validation       Json?
  pinned           Boolean         @default(false)
  visibleToGuests  Boolean         @default(true) @map("visible_to_guests")
  fillMethod       String          @default("manual") @map("fill_method")
  isBuiltin        Boolean         @default(false) @map("is_builtin")
  sortOrder        Int             @default(0) @map("sort_order")
  createdById      String?         @map("created_by_id")
  groupId          String?         @map("group_id")
  groupName        String?         @map("group_name")
  groupPosition    Int?            @map("group_position")
  groupColor       String?         @map("group_color")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")

  workspace          Workspace?              @relation(fields: [workspaceId], references: [id])
  space              Space?                  @relation("CustomFieldOnSpace", fields: [spaceId], references: [id])
  folder             Folder?                 @relation("CustomFieldOnFolder", fields: [folderId], references: [id])
  list               List?                   @relation("CustomFieldOnList", fields: [listId], references: [id])
  customTaskType     CustomTaskType?         @relation("CustomFieldOnTaskType", fields: [customTaskTypeId], references: [id])
  createdBy          User?                   @relation("CustomFieldCreator", fields: [createdById], references: [id])
  group              CustomFieldGroup?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  values             CustomFieldValue[]
  templateFields     TaskTypeTemplateField[]
  statusRequirements StatusRequiredField[]
  listLinks          CustomFieldList[]
  folderLinks        CustomFieldFolder[]
  spaceLinks         CustomFieldSpace[]

  @@unique([workspaceId, key, spaceId, folderId, listId, customTaskTypeId], map: "cfd_workspace_scoped_key_unique")
  @@index([workspaceId, deletedAt])
  @@index([workspaceId, type], name: "idx_cfd_workspace_type")
  @@index([spaceId], name: "idx_cfd_space")
  @@index([folderId], name: "idx_cfd_folder")
  @@index([listId], name: "idx_cfd_list")
  @@index([customTaskTypeId], name: "idx_cfd_task_type")
  @@index([createdById], name: "idx_cfd_created_by")
  @@map("custom_field_definitions")
}

/// CustomFieldValue — valor persistido para um par (workItem, definition).
/// Uma coluna valor preenchida por vez, dispatch pelo type da definition:
///   - valueText: TEXT, DROPDOWN, CPF, CNPJ, URL, EMAIL, PHONE
///   - valueNumber: NUMBER, CURRENCY (Decimal 18,4 acomoda centavos e moeda)
///   - valueDate: DATE
/// ON DELETE CASCADE em workItemId remove valores quando task e deletada.
model CustomFieldValue {
  id           String    @id @default(cuid())
  workItemId   String    @map("work_item_id")
  definitionId String    @map("definition_id")
  valueText    String?   @map("value_text") @db.Text
  valueNumber  Decimal?  @map("value_number") @db.Decimal(18, 4)
  valueDate    DateTime? @map("value_date")
  valueJson    Json?     @map("value_json")
  valueBoolean Boolean?  @map("value_boolean")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  workItem   WorkItem              @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  definition CustomFieldDefinition @relation(fields: [definitionId], references: [id])

  @@unique([workItemId, definitionId])
  @@index([workItemId])
  @@map("custom_field_values")
}

model CustomFieldGroup {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  color       String?
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace   Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  definitions CustomFieldDefinition[]
  listLinks   CustomFieldList[]
  folderLinks CustomFieldFolder[]
  spaceLinks  CustomFieldSpace[]

  @@index([workspaceId])
  @@map("custom_field_groups")
}

model CustomFieldList {
  id            String   @id @default(cuid())
  customFieldId String   @map("custom_field_id")
  listId        String   @map("list_id")
  groupId       String?  @map("group_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  customField CustomFieldDefinition @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  list        List                  @relation(fields: [listId], references: [id], onDelete: Cascade)
  group       CustomFieldGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([customFieldId, listId])
  @@index([listId])
  @@index([customFieldId])
  @@map("custom_field_lists")
}

model CustomFieldFolder {
  id            String   @id @default(cuid())
  customFieldId String   @map("custom_field_id")
  folderId      String   @map("folder_id")
  groupId       String?  @map("group_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  customField CustomFieldDefinition @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  folder      Folder                @relation(fields: [folderId], references: [id], onDelete: Cascade)
  group       CustomFieldGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([customFieldId, folderId])
  @@index([folderId])
  @@index([customFieldId])
  @@map("custom_field_folders")
}

model CustomFieldSpace {
  id            String   @id @default(cuid())
  customFieldId String   @map("custom_field_id")
  spaceId       String   @map("space_id")
  groupId       String?  @map("group_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  customField CustomFieldDefinition @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  space       Space                 @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  group       CustomFieldGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([customFieldId, spaceId])
  @@index([spaceId])
  @@index([customFieldId])
  @@map("custom_field_spaces")
}

// ============================================================================
// Task Types Templates — M2 (Migration task_type_templates, TTT-030)
// ----------------------------------------------------------------------------
// Plano: .claude/plan/PLANO-TASK-TYPES-TEMPLATES.md §"Modelo de Dados → M2".
// Template 1:1 com CustomTaskType. Define defaults funcionais por tipo de
// task: categorias de anexo (com mimeWhitelist e flag required) e descricao
// inicial em BlockNote AST. M:N com CustomFieldDefinition via
// TaskTypeTemplateField — ordena os fields e permite override de "required".
// Aditivo: zero ALTER em tabelas existentes alem das relacoes reversas
// (CustomTaskType.template, CustomFieldDefinition.templateFields).
// ============================================================================

/// TaskTypeTemplate — template funcional 1:1 com CustomTaskType.
/// MVP read-only via API; populado via seeds idempotentes.
/// Soft delete preserva templates removidos para auditoria.
model TaskTypeTemplate {
  id                       String    @id @default(cuid())
  customTaskTypeId         String    @unique @map("custom_task_type_id")
  attachmentCategories     Json?     @map("attachment_categories")
  defaultDescriptionBlocks Json?     @map("default_description_blocks")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  deletedAt                DateTime? @map("deleted_at")

  customTaskType CustomTaskType          @relation(fields: [customTaskTypeId], references: [id], onDelete: Cascade)
  fields         TaskTypeTemplateField[]

  @@index([deletedAt])
  @@map("task_type_templates")
}

/// TaskTypeTemplateField — join M:N entre TaskTypeTemplate e
/// CustomFieldDefinition. PK composta garante 1 entrada por (template, def).
/// `requiredOverride` permite que o template torne campo obrigatorio mesmo
/// quando definition.required=false (sobreposicao por contexto).
model TaskTypeTemplateField {
  templateId       String   @map("template_id")
  definitionId     String   @map("definition_id")
  sortOrder        Int      @default(0) @map("sort_order")
  requiredOverride Boolean? @map("required_override")

  template   TaskTypeTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  definition CustomFieldDefinition @relation(fields: [definitionId], references: [id])

  @@id([templateId, definitionId])
  @@index([templateId, sortOrder])
  @@map("task_type_template_fields")
}

enum FavoriteEntity {
  SPACE
  FOLDER
  LIST
  TASK
  CHAT_CHANNEL
}

enum FavoritePosition {
  TOP
  SIDEBAR
  BOTTOM
}

model Favorite {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  workspaceId String           @map("workspace_id")
  entityType  FavoriteEntity   @map("entity_type")
  entityId    String           @map("entity_id")
  position    FavoritePosition @default(SIDEBAR)
  order       Int              @default(0)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, entityType, entityId], name: "uniq_user_workspace_entity")
  @@index([userId, workspaceId, position, order])
  @@map("favorites")
}

model UserChannelOrganization {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  workspaceId      String   @map("workspace_id")
  organizationData Json     @map("organization_data")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("user_channel_organizations")
}

enum NotificationPreferenceType {
  TASK_ASSIGNED
  TASK_DUE_SOON
  TASK_OVERDUE
  TASK_COMMENT
  TASK_STATUS_CHANGE
  MENTION
  TASK_NAME_CHANGE
  TASK_DESCRIPTION_CHANGE
  TASK_PRIORITY_CHANGE
  TASK_DUE_DATE_CHANGE
  TASK_START_DATE_CHANGE
  TASK_CUSTOM_FIELD_CHANGE
  ACCESS_REQUESTED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

model NotificationPreference {
  id        String                     @id @default(cuid())
  userId    String                     @map("user_id")
  type      NotificationPreferenceType
  channels  NotificationChannel[]      @default([])
  enabled   Boolean                    @default(true)
  createdAt DateTime                   @default(now()) @map("created_at")
  updatedAt DateTime                   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("notification_preferences")
}
