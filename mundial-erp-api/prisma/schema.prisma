// Ver PLANO-TASKS.md secao 5.1.
enum TaskTemplateScope {
  WORKSPACE
  DEPARTMENT
  PROCESS
}

enum ChecklistItemSource {
  MANUAL
  TEMPLATE
}

enum TaskActivityType {
  CREATED
  RENAMED
  DESCRIPTION_CHANGED
  STATUS_CHANGED
  PRIORITY_CHANGED
  DUE_DATE_CHANGED
  START_DATE_CHANGED
  ASSIGNEE_ADDED
  ASSIGNEE_REMOVED
  WATCHER_ADDED
  WATCHER_REMOVED
  TAG_ADDED
  TAG_REMOVED
  CUSTOM_TYPE_CHANGED
  POINTS_CHANGED
  ARCHIVED
  UNARCHIVED
  MERGED_INTO
  DEPENDENCY_ADDED
  DEPENDENCY_REMOVED
  LINK_ADDED
  LINK_REMOVED
  CHECKLIST_CREATED
  CHECKLIST_ITEM_RESOLVED
  ATTACHMENT_ADDED
  SUBTASK_ADDED
  SUBTASK_COMPLETED
  COMMENT_ADDED
