  UPDATE
  DELETE
  STATUS_CHANGE
  LOGIN
  LOGOUT
  SYNC
}

enum ProductClassification {
  FABRICACAO_PROPRIA
  REVENDA
  MATERIA_PRIMA
  INSUMO
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum SeparationOrderStatus {
  PENDING
  IN_PROGRESS
  SEPARATED
  CHECKED
}

enum StockRequisitionType {
  VENDA
  INTERNO
}

enum StockRequisitionStatus {
  PENDING
  APPROVED
  PROCESSED
  CANCELLED
