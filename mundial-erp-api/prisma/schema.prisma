  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@unique([entity, proFinancasId])
  @@index([entity, mundialErpId], name: "idx_sync_entity_erp")
  @@map("sync_mappings")
