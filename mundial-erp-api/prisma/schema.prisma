  TOKEN_EXPIRED
  REVOKED
  SUSPENDED
}

enum KommoMessageDirection {
  IN
  OUT
}

enum KommoConversationStatus {
  OPEN
  WAITING_RESPONSE
  WAITING_CLIENT
  RESOLVED
  ARCHIVED
}

enum KommoWebhookEventStatus {
  RECEIVED
  PROCESSED
  DEDUPLICATED
  DLQ
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum MemberPermission {
  FULL_EDIT
  EDIT
  COMMENT
  VIEW
}

enum StatusInheritance {
  SPACE
  FOLDER
  CUSTOM
}

enum AutomationTrigger {
  TASK_CREATED
  TASK_STATUS_CHANGED
  TASK_UPDATED
  TASK_PRIORITY_CHANGED
  TASK_NAME_CHANGED
  TASK_TYPE_CHANGED
  TASK_DUE_DATE_CHANGED
  TASK_START_DATE_CHANGED
  TASK_ASSIGNED
  TASK_MOVED_TO_LIST
  ASSIGNEE_REMOVED
  TAG_ADDED
  TAG_REMOVED
  COMMENT_CREATED
  SUBTASK_CREATED
  ALL_SUBTASKS_RESOLVED
  CUSTOMFIELD_CHANGED
  CRON
}

enum AutomationScopeType {
  WORKSPACE
  SPACE
  FOLDER
  LIST
}

enum LinkType {
  RELATES_TO
  DUPLICATES
  IS_DUPLICATED_BY
}

// ============================================================================
// 1.2 — Auth & Organization
// ============================================================================

model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  name                    String
  passwordHash            String    @map("password_hash")
  refreshToken            String?   @map("refresh_token")
  role                    Role      @default(OPERATOR)
  isActive                Boolean   @default(true) @map("is_active")
  spaceId                 String?   @map("space_id")
  lastAccessedWorkspaceId String?   @map("last_accessed_workspace_id")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  space Space? @relation(fields: [spaceId], references: [id])

  spacesCreated  Space[]  @relation("SpaceCreator")
  foldersCreated Folder[] @relation("FolderCreator")
  listsCreated   List[]   @relation("ListCreator")

  spaceMemberships         SpaceMember[]           @relation("SpaceMemberUser")
  folderMemberships        FolderMember[]          @relation("FolderMemberUser")
  listMemberships          ListMember[]            @relation("ListMemberUser")
  spaceMembershipsAddedBy  SpaceMember[]           @relation("SpaceMemberAddedBy")
  folderMembershipsAddedBy FolderMember[]          @relation("FolderMemberAddedBy")
  listMembershipsAddedBy   ListMember[]            @relation("ListMemberAddedBy")
  commentsAssigned         WorkItemComment[]       @relation("CommentAssignee")
  commentsAssignedBy       WorkItemComment[]       @relation("CommentAssignedBy")
  commentsResolved         WorkItemComment[]       @relation("CommentResolvedBy")
  commentReactions         CommentReaction[]       @relation("CommentReactionUser")
  workItemTimeEntries      WorkItemTimeEntry[]     @relation("TimeEntryUser")
  automationsCreated       Automation[]            @relation("AutomationCreator")
  customFieldsCreated      CustomFieldDefinition[] @relation("CustomFieldCreator")

  // --- Workspace ---
  lastAccessedWorkspace Workspace?        @relation("LastAccessedWorkspace", fields: [lastAccessedWorkspaceId], references: [id])
  workspaceMembers      WorkspaceMember[]
  ownedWorkspaces       Workspace[]       @relation("WorkspaceOwner")
  workspaceInvites      WorkspaceInvite[] @relation("InvitedBy")

  createdOrders              Order[]            @relation("OrderCreatedBy")
  assignedOrders             Order[]            @relation("OrderAssignedTo")
  dashboards                 Dashboard[]
  cashRegistersOpened        CashRegister[]     @relation("CashOpenedBy")
  cashRegistersClosed        CashRegister[]     @relation("CashClosedBy")
  auditLogs                  AuditLog[]
  stockRequisitionsRequested StockRequisition[] @relation("RequisitionRequestedBy")
  stockRequisitionsApproved  StockRequisition[] @relation("RequisitionApprovedBy")
  orderItemSuppliesChecked   OrderItemSupply[]
  productionOrdersAssigned   ProductionOrder[]

  // --- WorkItems ---
  workItemsAssigned WorkItem[] @relation("WorkItemAssignee")
  workItemsCreated  WorkItem[] @relation("WorkItemCreator")

  // --- WorkItems collaboration (Sprint 2 Migration 2/3 tasks_collaboration) ---
  workItemAssignments WorkItemAssignee[] @relation("WorkItemAssigneeUser")
  workItemWatchings   WorkItemWatcher[]  @relation("WorkItemWatcherUser")

  // --- WorkItems advanced (Sprint 3-4 Migration 3/3 tasks_advanced) ---
  checklistItemAssignments WorkItemChecklistItem[] @relation("ChecklistItemAssignee")
  workItemAttachments      WorkItemAttachment[]    @relation("AttachmentUploader")
  workItemComments         WorkItemComment[]       @relation("CommentAuthor")
  workItemActivities       WorkItemActivity[]      @relation("TaskActivityActor")

  // --- Chat ---
  chatChannelsCreated      ChatChannel[]         @relation("ChatChannelCreatedBy")
  chatChannelMemberships   ChatChannelMember[]
  chatMessages             ChatMessage[]         @relation("ChatMessageAuthor")
  chatMessagesAssigned     ChatMessage[]         @relation("ChatMessageAssignee")
  chatReactions            ChatReaction[]
  chatMentions             ChatMention[]
  chatMessageFollowerships ChatMessageFollower[]

  // --- Notifications ---
  notifications Notification[]

  // --- Kommo (Sprint 2 migration kommo_foundations_2) ---
  kommoAgents KommoAgent[] @relation("KommoAgentMappedUser")

  favorites Favorite[]

  customTaskTypesCreated CustomTaskType[] @relation("CustomTaskTypeCreator")

  channelOrganizations UserChannelOrganization[]

  notificationPreferences NotificationPreference[]

  @@map("users")
}

model Permission {
  id          String  @id @default(cuid())
  action      String // e.g. "order:create"
  resource    String
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role         Role
  permissionId String @map("permission_id")

  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([role, permissionId])
  @@map("role_permissions")
}

// ============================================================================
// 1.3 — BPM Definition Layer
// ============================================================================

model Space {
  id                String     @id @default(cuid())
  workspaceId       String?    @map("workspace_id")
  name              String
  slug              String
  description       String?
  icon              String?
  color             String?
  visibility        Visibility @default(PUBLIC)
  isPrivate         Boolean    @default(false) @map("is_private")
  isDefault         Boolean    @default(false) @map("is_default")
  isProtected       Boolean    @default(false) @map("is_protected")
  position          Int        @default(0)
  creatorId         String?    @map("creator_id")
  defaultTaskTypeId String?    @map("default_task_type_id")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  deletedAt         DateTime?  @map("deleted_at")

  workspace         Workspace?              @relation(fields: [workspaceId], references: [id])
  creator           User?                   @relation("SpaceCreator", fields: [creatorId], references: [id])
  defaultTaskType   CustomTaskType?         @relation("SpaceDefaultTaskType", fields: [defaultTaskTypeId], references: [id])
  sectors           Sector[]
  folders           Folder[]
  users             User[]
  statuses          Status[]
  lists             List[]                  @relation("ListSpace")
  members           SpaceMember[]
  customFields      CustomFieldDefinition[] @relation("CustomFieldOnSpace")
  customFieldLinks  CustomFieldSpace[]
  customTaskTypes   CustomTaskType[]        @relation("SpaceTaskTypes")
  tags              WorkItemTag[]
  workItemTemplates WorkItemTemplate[]      @relation("TemplateSpace")

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_spaces_ws_deleted")
  @@map("spaces")
}

model Sector {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  spaceId   String    @map("space_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  space Space  @relation(fields: [spaceId], references: [id])
  lists List[] @relation("ListSector")

  @@map("sectors")
}

model Folder {
  id                String            @id @default(cuid())
  name              String
  slug              String
  description       String?
  spaceId           String            @map("space_id")
  isPrivate         Boolean           @default(false) @map("is_private")
  icon              String?
  color             String?
  visibility        Visibility        @default(PUBLIC)
  useSpaceStatuses  Boolean           @default(true) @map("use_space_statuses")
  statusInheritance StatusInheritance @default(SPACE) @map("status_inheritance")
  position          Int               @default(0)
  creatorId         String?           @map("creator_id")
  defaultTaskTypeId String?           @map("default_task_type_id")
  isDefault         Boolean           @default(false) @map("is_default")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  deletedAt         DateTime?         @map("deleted_at")

  space           Space                   @relation(fields: [spaceId], references: [id])
  creator         User?                   @relation("FolderCreator", fields: [creatorId], references: [id])
  defaultTaskType CustomTaskType?         @relation("FolderDefaultTaskType", fields: [defaultTaskTypeId], references: [id])
  lists           List[]                  @relation("ListFolder")
  statuses        Status[]                @relation("FolderStatuses")
  members         FolderMember[]
  customFields    CustomFieldDefinition[] @relation("CustomFieldOnFolder")
  customFieldLinks CustomFieldFolder[]

  @@unique([spaceId, slug])
  @@index([spaceId], name: "idx_folders_space")
  @@map("folders")
}

model List {
  id                String            @id @default(cuid())
  name              String
  slug              String
  description       String?
  sectorId          String?           @map("sector_id")
  spaceId           String?           @map("space_id")
  folderId          String?           @map("folder_id")
  processType       ProcessType       @default(LIST) @map("process_type")
  featureRoute      String?           @map("feature_route")
  icon              String?
  visibility        Visibility        @default(PUBLIC)
  statusInheritance StatusInheritance @default(FOLDER) @map("status_inheritance")
  isPrivate         Boolean           @default(false) @map("is_private")
  isProtected       Boolean           @default(false) @map("is_protected")
  status            ProcessStatus     @default(DRAFT)
  position          Int               @default(0)
  creatorId         String?           @map("creator_id")
  defaultTaskTypeId String?           @map("default_task_type_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  deletedAt         DateTime?         @map("deleted_at")

  sector            Sector?                 @relation("ListSector", fields: [sectorId], references: [id])
  space             Space?                  @relation("ListSpace", fields: [spaceId], references: [id])
  folder            Folder?                 @relation("ListFolder", fields: [folderId], references: [id])
  creator           User?                   @relation("ListCreator", fields: [creatorId], references: [id])
  defaultTaskType   CustomTaskType?         @relation("ListDefaultTaskType", fields: [defaultTaskTypeId], references: [id])
  activities        Activity[]
  handoffsFrom      Handoff[]               @relation("HandoffFrom")
  handoffsTo        Handoff[]               @relation("HandoffTo")
  workItems         WorkItem[]
  views             ProcessView[]
  members           ListMember[]
  customFields      CustomFieldDefinition[] @relation("CustomFieldOnList")
  customFieldLinks  CustomFieldList[]
  workItemTemplates WorkItemTemplate[]      @relation("TemplateList")
  statuses          Status[]                @relation("ListStatuses")

  @@unique([spaceId, slug])
  @@index([spaceId], name: "idx_lists_space")
  @@index([folderId], name: "idx_lists_folder")
  @@map("lists")
}

model SpaceMember {
  spaceId    String           @map("space_id")
  userId     String           @map("user_id")
  permission MemberPermission @default(VIEW)
  addedAt    DateTime         @default(now()) @map("added_at")
  addedBy    String?          @map("added_by")

  space       Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user        User  @relation("SpaceMemberUser", fields: [userId], references: [id])
  addedByUser User? @relation("SpaceMemberAddedBy", fields: [addedBy], references: [id])

  @@id([spaceId, userId])
  @@index([userId], name: "idx_space_members_user")
  @@map("space_members")
}

model FolderMember {
  folderId   String           @map("folder_id")
  userId     String           @map("user_id")
  permission MemberPermission @default(VIEW)
  addedAt    DateTime         @default(now()) @map("added_at")
  addedBy    String?          @map("added_by")

  folder      Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user        User   @relation("FolderMemberUser", fields: [userId], references: [id])
  addedByUser User?  @relation("FolderMemberAddedBy", fields: [addedBy], references: [id])

  @@id([folderId, userId])
  @@index([userId], name: "idx_folder_members_user")
  @@map("folder_members")
}

model ListMember {
  listId     String           @map("list_id")
  userId     String           @map("user_id")
  permission MemberPermission @default(VIEW)
  addedAt    DateTime         @default(now()) @map("added_at")
  addedBy    String?          @map("added_by")

  list        List  @relation(fields: [listId], references: [id], onDelete: Cascade)
  user        User  @relation("ListMemberUser", fields: [userId], references: [id])
  addedByUser User? @relation("ListMemberAddedBy", fields: [addedBy], references: [id])

  @@id([listId, userId])
  @@index([userId], name: "idx_list_members_user")
  @@map("list_members")
}

model Activity {
  id                String       @id @default(cuid())
  name              String // verbo infinitivo + objeto
  slug              String       @unique
  listId            String       @map("list_id")
  ownerRole         Role         @map("owner_role")
  inputDescription  String?      @map("input_description")
  outputDescription String?      @map("output_description")
  slaMinutes        Int?         @map("sla_minutes")
  exceptions        String?
  sortOrder         Int          @default(0) @map("sort_order")
  isAutomatic       Boolean      @default(false) @map("is_automatic")
  triggerOnStatus   OrderStatus? @map("trigger_on_status")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  deletedAt         DateTime?    @map("deleted_at")

  list  List   @relation(fields: [listId], references: [id])
  tasks Task[]

  @@map("activities")
}

model Task {
  id          String    @id @default(cuid())
  activityId  String    @map("activity_id")
  description String
  sortOrder   Int       @default(0) @map("sort_order")
  isMandatory Boolean   @default(true) @map("is_mandatory")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  activity Activity @relation(fields: [activityId], references: [id])

  @@map("tasks")
}

model Handoff {
  id              String       @id @default(cuid())
  fromListId      String       @map("from_list_id")
  toListId        String       @map("to_list_id")
  triggerOnStatus OrderStatus? @map("trigger_on_status")
  validationRules Json?        @map("validation_rules")
  autoAdvance     Boolean      @default(false) @map("auto_advance")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  fromList List @relation("HandoffFrom", fields: [fromListId], references: [id])
  toList   List @relation("HandoffTo", fields: [toListId], references: [id])

  @@map("handoffs")
}

// ============================================================================
// 1.4b — Workflow Status System (per Space)
// ============================================================================

model Status {
  id        String     @id @default(cuid())
  name      String
  type      StatusType
  color     String
  position  Int        @default(0)
  spaceId   String?    @map("space_id")
  folderId  String?    @map("folder_id")
  listId    String?    @map("list_id")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  deletedAt DateTime?  @map("deleted_at")

  space     Space?     @relation(fields: [spaceId], references: [id])
  folder    Folder?    @relation("FolderStatuses", fields: [folderId], references: [id])
  list      List?      @relation("ListStatuses", fields: [listId], references: [id])
  workItems WorkItem[]

  statusHistory  WorkItemStatusHistory[] @relation("StatusHistoryStatus")
  requiredFields StatusRequiredField[]

  @@index([spaceId, position], name: "idx_statuses_space_position")
  @@index([folderId, position], name: "idx_statuses_folder_position")
  @@index([listId, position], name: "idx_statuses_list_position")
  @@map("statuses")
}

model StatusRequiredField {
  id            String   @id @default(cuid())
  statusId      String   @map("status_id")
  customFieldId String   @map("custom_field_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  status      Status                @relation(fields: [statusId], references: [id], onDelete: Cascade)
  customField CustomFieldDefinition @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([statusId, customFieldId])
  @@index([statusId])
  @@map("status_required_fields")
}

model StatusTemplate {
  id          String   @id @default(cuid())
  workspaceId String?  @map("workspace_id")
  name        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace?           @relation(fields: [workspaceId], references: [id])
  items     StatusTemplateItem[]

  @@index([workspaceId])
  @@map("status_templates")
}

model StatusTemplateItem {
  id         String     @id @default(cuid())
  templateId String     @map("template_id")
  name       String
  type       StatusType
  color      String
  position   Int        @default(0)

  template StatusTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("status_template_items")
}

// ============================================================================
// 1.4c — WorkItems (generic items for LIST processes)
// ============================================================================

model WorkItem {
  id                   String       @id @default(cuid())
  listId               String       @map("list_id")
  title                String
  description          String?      @db.Text
  statusId             String       @map("status_id")
  itemType             WorkItemType @default(TASK) @map("item_type")
  priority             TaskPriority @default(NONE)
  /// CACHE DERIVADO: nunca escrever direto. Atualizado pela Prisma extension
  /// `primary-assignee-cache.extension.ts` em eventos de insert/delete de
  /// WorkItemAssignee (Migration 2). Lint rule custom bloqueia SET direto.
  /// Ver ADR-001.
  primaryAssigneeCache String?      @map("primary_assignee_cache")
  creatorId            String       @map("creator_id")
  parentId             String?      @map("parent_id")
  startDate            DateTime?    @map("start_date")
  dueDate              DateTime?    @map("due_date")
  completedAt          DateTime?    @map("completed_at")
  closedAt             DateTime?    @map("closed_at")
  estimatedMinutes     Int?         @map("estimated_minutes")
  trackedMinutes       Int          @default(0) @map("tracked_minutes")
  sortOrder            Int          @default(0) @map("sort_order")

  // Tasks feature (Sprint 1 Migration 1/3 tasks_foundations) — additive-only, tudo nullable.
  markdownContent  String?   @map("markdown_content") @db.Text
  points           Decimal?  @db.Decimal(10, 2)
  archived         Boolean   @default(false)
  archivedAt       DateTime? @map("archived_at")
  customTypeId     String?   @map("custom_type_id")
  mergedIntoId     String?   @map("merged_into_id")
  // CTO note #7: Int em segundos (64k dias cabem em Int32); evita BigInt no JSON.
  timeSpentSeconds Int       @default(0) @map("time_spent_seconds")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  list            List            @relation(fields: [listId], references: [id])
  status          Status          @relation(fields: [statusId], references: [id])
  primaryAssignee User?           @relation("WorkItemAssignee", fields: [primaryAssigneeCache], references: [id])
  creator         User            @relation("WorkItemCreator", fields: [creatorId], references: [id])
  parent          WorkItem?       @relation("Subtasks", fields: [parentId], references: [id])
  children        WorkItem[]      @relation("Subtasks")
  customType      CustomTaskType? @relation(fields: [customTypeId], references: [id])
  mergedInto      WorkItem?       @relation("MergeTarget", fields: [mergedIntoId], references: [id])
  merges          WorkItem[]      @relation("MergeTarget")

  assignees     WorkItemAssignee[]
  watchers      WorkItemWatcher[]
  tags          WorkItemTagLink[]
  checklists    WorkItemChecklist[]
  attachments   WorkItemAttachment[]
  comments      WorkItemComment[]
  statusHistory WorkItemStatusHistory[]
  linksFrom     WorkItemLink[]          @relation("LinkFrom")
  linksTo       WorkItemLink[]          @relation("LinkTo")
  activities    WorkItemActivity[]
  timeEntries   WorkItemTimeEntry[]

  // Task Types Templates — M1 Custom Fields (Migration custom_fields, TTT-010).
  // Modulo autonomo: valores de campos personalizados associados a esta task.
  customFieldValues CustomFieldValue[]

  @@index([listId, statusId], name: "idx_work_items_list_status")
  @@index([primaryAssigneeCache, statusId], name: "idx_work_items_assignee_status")
  @@index([dueDate], name: "idx_work_items_due_date")
  @@index([parentId], name: "idx_work_items_parent")
  @@index([listId, deletedAt, parentId], name: "idx_workitems_list_deleted_parent")
  @@index([primaryAssigneeCache, dueDate], name: "idx_work_items_assignee_due")
  @@index([archived, listId, deletedAt], name: "idx_work_items_archived_list")
  @@index([customTypeId], name: "idx_work_items_custom_type")
  @@index([mergedIntoId], name: "idx_work_items_merged_into")
  @@map("work_items")
}

// ============================================================================
// Tasks feature — Custom Task Types e Outbox (Migration 1/3 tasks_foundations)
// Ver PLANO-TASKS.md secao 5.3 e ADR-003.
// ============================================================================

/// CustomTaskType — builtin (workspaceId NULL) + custom por workspace.
/// Builtins sao seeds (Tarefa, Marco); workspace pode futuramente criar
/// tipos proprios. API expoe apenas leitura (GET /custom-task-types).
model CustomTaskType {
  id          String    @id @default(cuid())
  workspaceId String?   @map("workspace_id")
  spaceId     String?   @map("space_id")
  creatorId   String?   @map("creator_id")
  name        String
  namePlural  String?   @map("name_plural")
  description String?
  icon        String?
  color       String?
  avatarUrl   String?   @map("avatar_url")
  isBuiltin   Boolean   @default(false) @map("is_builtin")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  workspace        Workspace?              @relation(fields: [workspaceId], references: [id])
  space            Space?                  @relation("SpaceTaskTypes", fields: [spaceId], references: [id])
  creator          User?                   @relation("CustomTaskTypeCreator", fields: [creatorId], references: [id])
  workItems        WorkItem[]
  spacesAsDefault  Space[]                 @relation("SpaceDefaultTaskType")
  foldersAsDefault Folder[]                @relation("FolderDefaultTaskType")
  listsAsDefault   List[]                  @relation("ListDefaultTaskType")
  template         TaskTypeTemplate?
  customFields     CustomFieldDefinition[] @relation("CustomFieldOnTaskType")

  @@index([workspaceId, deletedAt], name: "idx_custom_task_types_ws_deleted")
  @@index([spaceId], name: "idx_custom_task_types_space")
  @@index([creatorId], name: "idx_custom_task_types_creator")
  @@map("custom_task_types")
}

/// TaskOutboxEvent — outbox pattern para side-effects garantidos (ADR-003).
/// Escrito na mesma $transaction do commit de WorkItem; worker BullMQ
/// consome com retry + DLQ. Limpeza periodica de COMPLETED > 30d (R14).
model TaskOutboxEvent {
  id          String            @id @default(cuid())
  aggregateId String            @map("aggregate_id")
  eventType   String            @map("event_type")
  payload     Json
  status      OutboxEventStatus @default(PENDING)
  attempts    Int               @default(0)
  lastError   String?           @map("last_error")
  createdAt   DateTime          @default(now()) @map("created_at")
  processedAt DateTime?         @map("processed_at")

  @@index([status, createdAt], name: "idx_outbox_status_created")
  @@index([aggregateId], name: "idx_outbox_aggregate")
  @@map("task_outbox_events")
}

// ============================================================================
// Tasks feature — Collaboration (Migration 2/3 tasks_collaboration)
// Multi-assignees (fonte unica), watchers, tags (case-insensitive), tag links.
// Ver PLANO-TASKS.md secao 5.3 e ADR-001.
// ============================================================================

/// Multi-assignees — fonte unica da verdade para quem esta atribuido a uma
/// task. `WorkItem.primaryAssigneeCache` e cache derivado escrito pela Prisma
/// extension (ADR-001) em eventos de insert/delete aqui.
model WorkItemAssignee {
  workItemId String   @map("work_item_id")
  userId     String   @map("user_id")
  isPrimary  Boolean  @default(false) @map("is_primary")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  user     User     @relation("WorkItemAssigneeUser", fields: [userId], references: [id])

  @@id([workItemId, userId])
  @@index([userId, workItemId], name: "idx_wi_assignees_user")
  @@index([workItemId, isPrimary], name: "idx_wi_assignees_primary")
  @@map("work_item_assignees")
}

/// Watchers — usuarios que seguem a task para receber notificacoes.
model WorkItemWatcher {
  workItemId String   @map("work_item_id")
  userId     String   @map("user_id")
  addedAt    DateTime @default(now()) @map("added_at")

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  user     User     @relation("WorkItemWatcherUser", fields: [userId], references: [id])

  @@id([workItemId, userId])
  @@index([userId], name: "idx_wi_watchers_user")
  @@map("work_item_watchers")
}

/// Tag por workspace. `nameLower` garante unicidade case-insensitive e
/// permite busca eficiente. Normalizado pela aplicacao (LOWER(name)).
model WorkItemTag {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  spaceId     String?   @map("space_id")
  name        String
  nameLower   String    @map("name_lower")
  color       String?
  bgColor     String?   @map("bg_color")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  workspace Workspace         @relation(fields: [workspaceId], references: [id])
  space     Space?            @relation(fields: [spaceId], references: [id])
  links     WorkItemTagLink[]

  @@unique([workspaceId, nameLower])
  @@index([workspaceId, deletedAt], name: "idx_wi_tags_ws_deleted")
  @@index([spaceId], name: "idx_wi_tags_space")
  @@map("work_item_tags")
}

/// Join table entre WorkItem e WorkItemTag (many-to-many).
model WorkItemTagLink {
  workItemId String @map("work_item_id")
  tagId      String @map("tag_id")

  workItem WorkItem    @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  tag      WorkItemTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([workItemId, tagId])
  @@index([tagId], name: "idx_wi_tag_links_tag")
  @@map("work_item_tag_links")
}

// ============================================================================
// Tasks feature — Advanced (Migration 3/3 tasks_advanced)
// Checklists, dependencies, links, status history, templates, attachments,
// comments e activities. Ver PLANO-TASKS.md secao 5.3.
// ============================================================================

/// Checklist por task (multiplas). Items sao nested (WorkItemChecklistItem).
model WorkItemChecklist {
  id         String    @id @default(cuid())
  workItemId String    @map("work_item_id")
  title      String
  position   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  workItem WorkItem                @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  items    WorkItemChecklistItem[]

  @@index([workItemId, position], name: "idx_checklists_wi_pos")
  @@map("work_item_checklists")
}

/// Item de checklist com nesting opcional (max depth 3 via service).
model WorkItemChecklistItem {
  id          String              @id @default(cuid())
  checklistId String              @map("checklist_id")
  parentId    String?             @map("parent_id")
  title       String
  assigneeId  String?             @map("assignee_id")
  resolved    Boolean             @default(false)
  resolvedAt  DateTime?           @map("resolved_at")
  resolvedBy  String?             @map("resolved_by")
  position    Int                 @default(0)
  source      ChecklistItemSource @default(MANUAL)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  deletedAt   DateTime?           @map("deleted_at")

  checklist WorkItemChecklist       @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  parent    WorkItemChecklistItem?  @relation("ChecklistItemNesting", fields: [parentId], references: [id])
  children  WorkItemChecklistItem[] @relation("ChecklistItemNesting")
  assignee  User?                   @relation("ChecklistItemAssignee", fields: [assigneeId], references: [id])

  @@index([checklistId, position], name: "idx_checklist_items_list_pos")
  @@index([parentId], name: "idx_checklist_items_parent")
  @@map("work_item_checklist_items")
}

model WorkItemLink {
  id         String   @id @default(cuid())
  fromTaskId String   @map("from_task_id")
  toTaskId   String   @map("to_task_id")
  type       LinkType @default(RELATES_TO)
  createdAt  DateTime @default(now()) @map("created_at")
  createdBy  String?  @map("created_by")

  fromTask WorkItem @relation("LinkFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  toTask   WorkItem @relation("LinkTo", fields: [toTaskId], references: [id], onDelete: Cascade)

  @@unique([fromTaskId, toTaskId, type])
  @@index([toTaskId], name: "idx_wi_links_to")
  @@map("work_item_links")
}

/// Time in Status — 1 linha por transicao de status. Worker outbox fecha a
/// linha anterior (`leftAt`, `durationSeconds`) e insere a nova.
/// Particionar por mes se ultrapassar 10M rows (R15).
model WorkItemStatusHistory {
  id              String    @id @default(cuid())
  workItemId      String    @map("work_item_id")
  statusId        String    @map("status_id")
  enteredAt       DateTime  @default(now()) @map("entered_at")
  leftAt          DateTime? @map("left_at")
  durationSeconds Int?      @map("duration_seconds")
  byUserId        String?   @map("by_user_id")

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  status   Status   @relation("StatusHistoryStatus", fields: [statusId], references: [id])

  @@index([workItemId, enteredAt(sort: Desc)], name: "idx_status_history_task_entered")
  @@map("work_item_status_history")
}

/// Template de task — snapshot para instanciacao em `List`.
/// Validador custom garante max 200 nodes cumulativos e depth <= 3.
model WorkItemTemplate {
  id             String            @id @default(cuid())
  workspaceId    String            @map("workspace_id")
  name           String
  scope          TaskTemplateScope @default(WORKSPACE)
  spaceId        String?           @map("space_id")
  listId         String?           @map("list_id")
  payload        Json
  subtaskCount   Int               @default(0) @map("subtask_count")
  checklistCount Int               @default(0) @map("checklist_count")
  createdBy      String?           @map("created_by")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  space     Space?    @relation("TemplateSpace", fields: [spaceId], references: [id])
  list      List?     @relation("TemplateList", fields: [listId], references: [id])

  @@index([workspaceId, scope, deletedAt], name: "idx_wi_templates_ws_scope_del")
  @@map("work_item_templates")
}

/// Attachment com signed-url upload e ClamAV scan async.
model WorkItemAttachment {
  id         String    @id @default(cuid())
  workItemId String    @map("work_item_id")
  filename   String
  mimeType   String    @map("mime_type")
  sizeBytes  Int       @map("size_bytes")
  storageKey String    @map("storage_key")
  scanStatus String    @default("PENDING") @map("scan_status")
  category   String?   @db.VarChar(64)
  uploadedBy String    @map("uploaded_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  uploader User     @relation("AttachmentUploader", fields: [uploadedBy], references: [id])

  @@index([workItemId, deletedAt], name: "idx_wi_attachments_task")
  @@index([workItemId, category], name: "idx_wi_attachments_task_category")
  @@map("work_item_attachments")
}

/// Comentario dedicado (nao reusa ChatChannel). BlockNote JSON opcional.
model WorkItemComment {
  id            String    @id @default(cuid())
  workItemId    String    @map("work_item_id")
  authorId      String    @map("author_id")
  parentId      String?   @map("parent_id")
  content       String    @db.Text
  contentBlocks Json?     @map("content_blocks")
  mentions      Json?
  assigneeId    String?   @map("assignee_id")
  assignedById  String?   @map("assigned_by_id")
  resolvedAt    DateTime? @map("resolved_at")
  resolvedById  String?   @map("resolved_by_id")
  source        String?
  editedAt      DateTime? @map("edited_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workItem   WorkItem          @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  author     User              @relation("CommentAuthor", fields: [authorId], references: [id])
  parent     WorkItemComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies    WorkItemComment[] @relation("CommentReplies")
  assignee   User?             @relation("CommentAssignee", fields: [assigneeId], references: [id])
  assignedBy User?             @relation("CommentAssignedBy", fields: [assignedById], references: [id])
  resolvedBy User?             @relation("CommentResolvedBy", fields: [resolvedById], references: [id])
  reactions  CommentReaction[]

  @@index([workItemId, createdAt(sort: Desc)], name: "idx_wi_comments_task_created")
  @@index([parentId], name: "idx_wi_comments_parent")
  @@index([assigneeId], name: "idx_wi_comments_assignee")
  @@map("work_item_comments")
}

model CommentReaction {
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  comment WorkItemComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User            @relation("CommentReactionUser", fields: [userId], references: [id])

  @@id([commentId, userId, emoji])
  @@index([userId], name: "idx_comment_reactions_user")
  @@map("comment_reactions")
}

/// Activity feed — projecao assincrona (ADR-002 + ADR-003).
/// Worker outbox enriquece `payload` com nomes antes de inserir.
model WorkItemActivity {
  id         String           @id @default(cuid())
  workItemId String           @map("work_item_id")
  type       TaskActivityType
  actorId    String?          @map("actor_id")
  payload    Json
  createdAt  DateTime         @default(now()) @map("created_at")

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  actor    User?    @relation("TaskActivityActor", fields: [actorId], references: [id])

  @@index([workItemId, createdAt(sort: Desc)], name: "idx_wi_activities_task_created")
  @@map("work_item_activities")
}

model WorkItemTimeEntry {
  id              String    @id @default(cuid())
  workItemId      String    @map("work_item_id")
  userId          String    @map("user_id")
  startTime       DateTime  @map("start_time")
  endTime         DateTime? @map("end_time")
  durationSeconds Int?      @map("duration_seconds")
  description     String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  user     User     @relation("TimeEntryUser", fields: [userId], references: [id])

  @@index([workItemId, userId, startTime], name: "idx_wi_time_entries_task_user_start")
  @@index([userId, startTime], name: "idx_wi_time_entries_user_start")
  @@map("work_item_time_entries")
}

// ============================================================================
// 1.4d — Process Views (per List)
// ============================================================================

model ProcessView {
  id        String    @id @default(cuid())
  listId    String    @map("list_id")
  name      String
  viewType  ViewType  @map("view_type")
  isPinned  Boolean   @default(false) @map("is_pinned")
  config    Json      @default("{}")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  list List @relation(fields: [listId], references: [id])

  @@index([listId], name: "idx_process_views_list")
  @@map("process_views")
}

// ============================================================================
// 1.5 — Business: Clients
// ============================================================================

model Client {
  id                     String     @id @default(cuid())
  workspaceId            String?    @map("workspace_id")
  personType             PersonType @map("person_type")
  cpfCnpj                String     @unique @map("cpf_cnpj")
  name                   String
  tradeName              String?    @map("trade_name")
  ie                     String?
  rg                     String?
  email                  String?
  phone                  String?
  address                String?
  addressNumber          String?    @map("address_number")
  neighborhood           String?
  complement             String?
  city                   String?
  state                  String?
  zipCode                String?    @map("zip_code")
  classificationId       String?    @map("classification_id")
  deliveryRouteId        String?    @map("delivery_route_id")
  defaultPriceTableId    String?    @map("default_price_table_id")
  defaultPaymentMethodId String?    @map("default_payment_method_id")
  proFinancasId          Int?       @map("pro_financas_id")
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")
  deletedAt              DateTime?  @map("deleted_at")

  workspace            Workspace?            @relation(fields: [workspaceId], references: [id])
  classification       ClientClassification? @relation(fields: [classificationId], references: [id])
  deliveryRoute        DeliveryRoute?        @relation(fields: [deliveryRouteId], references: [id])
  defaultPriceTable    PriceTable?           @relation(fields: [defaultPriceTableId], references: [id])
  defaultPaymentMethod PaymentMethod?        @relation(fields: [defaultPaymentMethodId], references: [id])
  orders               Order[]
  accountsReceivable   AccountReceivable[]
  invoices             Invoice[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_clients_ws_deleted")
  @@index([name], name: "idx_clients_name")
  @@index([cpfCnpj], name: "idx_clients_cpf_cnpj")
  @@index([proFinancasId], name: "idx_clients_pf_id")
  @@map("clients")
}

model ClientClassification {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  name          String
  proFinancasId Int?      @map("pro_financas_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  clients   Client[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_client_classifications_ws_deleted")
  @@map("client_classifications")
}

model DeliveryRoute {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  name          String
  proFinancasId Int?      @map("pro_financas_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  clients   Client[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_delivery_routes_ws_deleted")
  @@map("delivery_routes")
}

// ============================================================================
// 1.5b — Business: Products, Suppliers, Quotations
// ============================================================================

model Supplier {
  id            String     @id @default(cuid())
  workspaceId   String?    @map("workspace_id")
  personType    PersonType @map("person_type")
  cpfCnpj       String     @unique @map("cpf_cnpj")
  name          String
  tradeName     String?    @map("trade_name")
  ie            String?
  email         String?
  phone         String?
  address       String?
  city          String?
  state         String?
  zipCode       String?    @map("zip_code")
  isActive      Boolean    @default(true) @map("is_active")
  proFinancasId Int?       @map("pro_financas_id")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")

  workspace          Workspace?          @relation(fields: [workspaceId], references: [id])
  purchaseQuotations PurchaseQuotation[]
  purchaseOrders     PurchaseOrder[]
  accountsPayable    AccountPayable[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_suppliers_ws_deleted")
  @@map("suppliers")
}

model ProductType {
  id             String    @id @default(cuid())
  workspaceId    String?   @map("workspace_id")
  prefix         String    @unique // 2 chars, e.g. "TT"
  name           String
  eanDeptCode    String    @map("ean_dept_code") // 4 digits
  lastSequential Int       @default(0) @map("last_sequential")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  products  Product[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_product_types_ws_deleted")
  @@map("product_types")
}

model Product {
  id                   String                 @id @default(cuid())
  workspaceId          String?                @map("workspace_id")
  // Step 1 — Identification
  productTypeId        String                 @map("product_type_id")
  code                 String                 @unique
  barcode              String?                @unique
  name                 String
  departmentCategoryId String?                @map("department_category_id")
  brandId              String?                @map("brand_id")
  unitMeasureId        String?                @map("unit_measure_id")
  boxUnitMeasureId     String?                @map("box_unit_measure_id")
  unitsPerBox          Int?                   @map("units_per_box")
  step1Complete        Boolean                @default(false) @map("step1_complete")
  // Step 2 — Technical Specification
  weight               Float?
  width                Float?
  height               Float?
  length               Float?
  weightM3             Float?                 @map("weight_m3")
  productionCapacity   Float?                 @map("production_capacity")
  stockLocation        String?                @map("stock_location")
  minStock             Float                  @default(0) @map("min_stock")
  currentStock         Float                  @default(0) @map("current_stock")
  piecesPerUnit        Float?                 @map("pieces_per_unit")
  size                 Float?
  classification       ProductClassification?
  loadCapacity         Float?                 @map("load_capacity")
  beta                 Float?
  fckMpa               Float?                 @map("fck_mpa")
  step2Complete        Boolean                @default(false) @map("step2_complete")
  // Step 3 — Fiscal & Tax
  ncmCode              String?                @map("ncm_code")
  nfeOriginId          String?                @map("nfe_origin_id")
  cfopDefault          String?                @map("cfop_default")
  ipiRate              Float?                 @map("ipi_rate")
  taxBasketId          String?                @map("tax_basket_id")
  step3Complete        Boolean                @default(false) @map("step3_complete")
  // Step 4 — Pricing & Formula
  costPrice            Int                    @default(0) @map("cost_price")
  salePrice            Int                    @default(0) @map("sale_price")
  minSalePrice         Int                    @default(0) @map("min_sale_price")
  defaultPriceTableId  String?                @map("default_price_table_id")
  formulaId            String?                @unique @map("formula_id")
  step4Complete        Boolean                @default(false) @map("step4_complete")
  // Status
  status               ProductStatus          @default(DRAFT)
  proFinancasId        Int?                   @map("pro_financas_id")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  deletedAt            DateTime?              @map("deleted_at")

  workspace              Workspace?                    @relation(fields: [workspaceId], references: [id])
  productType            ProductType                   @relation(fields: [productTypeId], references: [id])
  departmentCategory     ProductDepartment?            @relation(fields: [departmentCategoryId], references: [id])
  brand                  Brand?                        @relation(fields: [brandId], references: [id])
  unitMeasure            UnitMeasure?                  @relation("ProductUnit", fields: [unitMeasureId], references: [id])
  boxUnitMeasure         UnitMeasure?                  @relation("ProductBoxUnit", fields: [boxUnitMeasureId], references: [id])
  defaultPriceTable      PriceTable?                   @relation(fields: [defaultPriceTableId], references: [id])
  formula                ProductionFormula?            @relation(fields: [formulaId], references: [id])
  images                 ProductImage[]
  priceTableItems        PriceTableItem[]
  orderItems             OrderItem[]
  orderItemSupplies      OrderItemSupply[]
  purchaseQuotationItems PurchaseQuotationItem[]
  productionOrderItems   ProductionOrderItem[]
  productionConsumptions ProductionConsumption[]
  productionOutputs      ProductionOutput[]
  separationOrderItems   SeparationOrderItem[]
  stockRequisitionItems  StockRequisitionItem[]
  formulaIngredients     ProductionFormulaIngredient[] @relation("FormulaIngredient")

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_products_ws_deleted")
  @@index([name], name: "idx_products_name")
  @@index([code], name: "idx_products_code")
  @@index([proFinancasId], name: "idx_products_pf_id")
  @@map("products")
}

model ProductImage {
  id        String    @id @default(cuid())
  productId String    @map("product_id")
  url       String
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("product_images")
}

model UnitMeasure {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  name          String
  proFinancasId Int?      @map("pro_financas_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workspace              Workspace?                    @relation(fields: [workspaceId], references: [id])
  productsAsUnit         Product[]                     @relation("ProductUnit")
  productsAsBoxUnit      Product[]                     @relation("ProductBoxUnit")
  productionOrderItems   ProductionOrderItem[]
  productionConsumptions ProductionConsumption[]
  productionOutputs      ProductionOutput[]
  formulaIngredients     ProductionFormulaIngredient[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_unit_measures_ws_deleted")
  @@map("unit_measures")
}

model Brand {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  name          String
  proFinancasId Int?      @map("pro_financas_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  products  Product[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_brands_ws_deleted")
  @@map("brands")
}

model ProductDepartment {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  name          String
  proFinancasId Int?      @map("pro_financas_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  products  Product[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_product_departments_ws_deleted")
  @@map("product_departments")
}

model PriceTable {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  name          String
  isDefault     Boolean   @default(false) @map("is_default")
  proFinancasId Int?      @map("pro_financas_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workspace       Workspace?       @relation(fields: [workspaceId], references: [id])
  items           PriceTableItem[]
  clientsDefault  Client[]
  productsDefault Product[]
  orders          Order[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_price_tables_ws_deleted")
  @@map("price_tables")
}

model PriceTableItem {
  id           String    @id @default(cuid())
  priceTableId String    @map("price_table_id")
  productId    String    @map("product_id")
  priceInCents Int       @map("price_in_cents")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  priceTable PriceTable @relation(fields: [priceTableId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  @@unique([priceTableId, productId])
  @@map("price_table_items")
}

model PurchaseQuotation {
  id          String    @id @default(cuid())
  supplierId  String    @map("supplier_id")
  status      String    @default("DRAFT") // DRAFT, SENT, RECEIVED, SELECTED, REJECTED, ORDERED
  requestedAt DateTime? @map("requested_at")
  receivedAt  DateTime? @map("received_at")
  totalCents  Int       @default(0) @map("total_cents")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  supplier Supplier                @relation(fields: [supplierId], references: [id])
  items    PurchaseQuotationItem[]

  @@map("purchase_quotations")
}

model PurchaseQuotationItem {
  id             String    @id @default(cuid())
  quotationId    String    @map("quotation_id")
  productId      String    @map("product_id")
  quantity       Float
  unitPriceCents Int       @map("unit_price_cents")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  quotation PurchaseQuotation @relation(fields: [quotationId], references: [id])
  product   Product           @relation(fields: [productId], references: [id])

  @@map("purchase_quotation_items")
}

model PurchaseOrder {
  id                   String    @id @default(cuid())
  supplierId           String    @map("supplier_id")
  quotationId          String?   @map("quotation_id")
  status               String    @default("PENDING") // PENDING, CONFIRMED, RECEIVED, CANCELLED
  totalCents           Int       @default(0) @map("total_cents")
  expectedDeliveryDate DateTime? @map("expected_delivery_date")
  notes                String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  supplier       Supplier        @relation(fields: [supplierId], references: [id])
  accountPayable AccountPayable?

  @@map("purchase_orders")
}

// ============================================================================
// 1.5c — Business: Reference Data
// ============================================================================

model Company {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  name          String
  tradeName     String?   @map("trade_name")
  cnpj          String?   @unique
  ie            String?
  phone         String?
  email         String?
  logoUrl       String?   @map("logo_url")
  address       String?
  city          String?
  state         String?
  zipCode       String?   @map("zip_code")
  proFinancasId Int?      @map("pro_financas_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workspace     Workspace?     @relation(fields: [workspaceId], references: [id])
  orders        Order[]
  invoices      Invoice[]
  cashRegisters CashRegister[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_companies_ws_deleted")
  @@map("companies")
}

model PaymentMethod {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  name          String
  isActive      Boolean   @default(true) @map("is_active")
  proFinancasId Int?      @map("pro_financas_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  clients   Client[]
  orders    Order[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_payment_methods_ws_deleted")
  @@map("payment_methods")
}

model Carrier {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  name          String
  proFinancasId Int?      @map("pro_financas_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  orders    Order[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_carriers_ws_deleted")
  @@map("carriers")
}

// ============================================================================
// 1.5d — Dashboards
// ============================================================================

model Dashboard {
  id                 String    @id @default(cuid())
  workspaceId        String?   @map("workspace_id")
  name               String
  description        String?
  ownerId            String    @map("owner_id")
  isPublic           Boolean   @default(false) @map("is_public")
  autoRefreshSeconds Int?      @map("auto_refresh_seconds")
  sortOrder          Int       @default(0) @map("sort_order")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  workspace Workspace?        @relation(fields: [workspaceId], references: [id])
  owner     User              @relation(fields: [ownerId], references: [id])
  cards     DashboardCard[]
  filters   DashboardFilter[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_dashboards_ws_deleted")
  @@map("dashboards")
}

model DashboardCard {
  id            String   @id @default(cuid())
  dashboardId   String   @map("dashboard_id")
  type          CardType
  title         String
  dataSource    Json     @map("data_source")
  filters       Json?
  axisConfig    Json?    @map("axis_config")
  layoutX       Int      @map("layout_x")
  layoutY       Int      @map("layout_y")
  layoutW       Int      @map("layout_w")
  layoutH       Int      @map("layout_h")
  config        Json?
  sortOrder     Int      @default(0) @map("sort_order")
  // schemaVersion: versao do shape JSON em `dataSource`/`filters`/`axisConfig`/`config`.
  // Requerido pelo principio #5 de `squad-dashboards.mdc`. Default 1 cobre cards
  // legados criados antes da coluna existir. Bumps sao aditivos e acompanhados
  // de transformador de leitura (RFC/ADR em `.claude/rfc/`).
  schemaVersion Int      @default(1) @map("schema_version")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  dashboard Dashboard @relation(fields: [dashboardId], references: [id])

  @@map("dashboard_cards")
}

model DashboardFilter {
  id          String   @id @default(cuid())
  dashboardId String   @map("dashboard_id")
  field       String
  operator    String // EQUALS, NOT_EQUALS, GREATER, LESS, BETWEEN, IN
  value       Json
  label       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  dashboard Dashboard @relation(fields: [dashboardId], references: [id])

  @@map("dashboard_filters")
}

// ============================================================================
// 1.6 — Order (central entity)
// ============================================================================

model Order {
  id                     String      @id @default(cuid())
  workspaceId            String?     @map("workspace_id")
  orderNumber            String      @unique @map("order_number")
  title                  String?
  status                 OrderStatus @default(EM_ORCAMENTO)
  clientId               String      @map("client_id")
  companyId              String?     @map("company_id")
  paymentMethodId        String?     @map("payment_method_id")
  carrierId              String?     @map("carrier_id")
  priceTableId           String?     @map("price_table_id")
  createdByUserId        String      @map("created_by_user_id")
  assignedUserId         String?     @map("assigned_user_id")
  issueDate              DateTime?   @map("issue_date")
  deliveryDeadline       DateTime?   @map("delivery_deadline")
  proposalValidityDays   Int         @default(7) @map("proposal_validity_days")
  deliveryAddress        String?     @map("delivery_address")
  deliveryNeighborhood   String?     @map("delivery_neighborhood")
  deliveryCity           String?     @map("delivery_city")
  deliveryState          String?     @map("delivery_state")
  deliveryCep            String?     @map("delivery_cep")
  deliveryReferencePoint String?     @map("delivery_reference_point")
  contactName            String?     @map("contact_name")
  subtotalCents          Int         @default(0) @map("subtotal_cents")
  freightCents           Int         @default(0) @map("freight_cents")
  discountCents          Int         @default(0) @map("discount_cents")
  taxSubstitutionCents   Int         @default(0) @map("tax_substitution_cents")
  totalCents             Int         @default(0) @map("total_cents")
  paidAmountCents        Int         @default(0) @map("paid_amount_cents")
  paymentProofUrl        String?     @map("payment_proof_url")
  shouldProduce          Boolean     @default(false) @map("should_produce")
  isResale               Boolean     @default(false) @map("is_resale")
  hasTaxSubstitution     Boolean     @default(false) @map("has_tax_substitution")
  notes                  String?
  proFinancasId          Int?        @map("pro_financas_id")
  orderTypeId            String?     @map("order_type_id")
  orderFlowId            String?     @map("order_flow_id")
  orderModelId           String?     @map("order_model_id")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")
  deletedAt              DateTime?   @map("deleted_at")

  workspace          Workspace?           @relation(fields: [workspaceId], references: [id])
  client             Client               @relation(fields: [clientId], references: [id])
  company            Company?             @relation(fields: [companyId], references: [id])
  paymentMethod      PaymentMethod?       @relation(fields: [paymentMethodId], references: [id])
  carrier            Carrier?             @relation(fields: [carrierId], references: [id])
  priceTable         PriceTable?          @relation(fields: [priceTableId], references: [id])
  createdBy          User                 @relation("OrderCreatedBy", fields: [createdByUserId], references: [id])
  assignedTo         User?                @relation("OrderAssignedTo", fields: [assignedUserId], references: [id])
  orderType          OrderType?           @relation(fields: [orderTypeId], references: [id])
  orderFlow          OrderFlow?           @relation(fields: [orderFlowId], references: [id])
  orderModel         OrderModel?          @relation(fields: [orderModelId], references: [id])
  items              OrderItem[]
  statusHistory      OrderStatusHistory[]
  invoices           Invoice[]
  productionOrders   ProductionOrder[]
  separationOrders   SeparationOrder[]
  accountsReceivable AccountReceivable[]
  stockRequisitions  StockRequisition[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_orders_ws_deleted")
  @@index([clientId, status], name: "idx_orders_client_status")
  @@index([status, createdAt], name: "idx_orders_status_created")
  @@index([createdByUserId], name: "idx_orders_created_by")
  @@index([proFinancasId], name: "idx_orders_pf_id")
  @@map("orders")
}

model OrderItem {
  id                     String                 @id @default(cuid())
  orderId                String                 @map("order_id")
  productId              String?                @map("product_id")
  productName            String?                @map("product_name")
  quantity               Float
  unitPriceCents         Int                    @map("unit_price_cents")
  discountCents          Int                    @default(0) @map("discount_cents")
  totalCents             Int                    @default(0) @map("total_cents")
  sortOrder              Int                    @default(0) @map("sort_order")
  pieces                 Float?
  size                   Float?
  classificationSnapshot ProductClassification? @map("classification_snapshot")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")
  deletedAt              DateTime?              @map("deleted_at")

  order                Order                 @relation(fields: [orderId], references: [id])
  product              Product?              @relation(fields: [productId], references: [id])
  supplies             OrderItemSupply[]
  productionOrderItems ProductionOrderItem[]
  separationOrderItems SeparationOrderItem[]

  @@map("order_items")
}

model OrderItemSupply {
  id                    String                @id @default(cuid())
  orderItemId           String                @map("order_item_id")
  productId             String?               @map("product_id")
  name                  String
  quantity              Int                   @default(1)
  status                OrderItemSupplyStatus @default(PENDING)
  readyAt               DateTime?             @map("ready_at")
  checkedByUserId       String?               @map("checked_by_user_id")
  separationOrderItemId String?               @map("separation_order_item_id")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")
  deletedAt             DateTime?             @map("deleted_at")

  orderItem           OrderItem            @relation(fields: [orderItemId], references: [id])
  product             Product?             @relation(fields: [productId], references: [id])
  checkedBy           User?                @relation(fields: [checkedByUserId], references: [id])
  separationOrderItem SeparationOrderItem? @relation(fields: [separationOrderItemId], references: [id])

  @@map("order_item_supplies")
}

model OrderStatusHistory {
  id              String      @id @default(cuid())
  orderId         String      @map("order_id")
  fromStatus      OrderStatus @map("from_status")
  toStatus        OrderStatus @map("to_status")
  changedByUserId String      @map("changed_by_user_id")
  reason          String?
  metadata        Json?
  createdAt       DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("order_status_history")
}

model OrderType {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  name          String
  proFinancasId Int?      @map("pro_financas_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  orders    Order[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_order_types_ws_deleted")
  @@map("order_types")
}

model OrderFlow {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  name          String
  proFinancasId Int?      @map("pro_financas_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  orders    Order[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_order_flows_ws_deleted")
  @@map("order_flows")
}

model OrderModel {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  name          String
  proFinancasId Int?      @map("pro_financas_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  orders    Order[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_order_models_ws_deleted")
  @@map("order_models")
}

model OrderSequence {
  id         String @id @default("singleton")
  lastNumber Int    @default(0) @map("last_number")

  @@map("order_sequences")
}

// ============================================================================
// 1.7 — Financial
// ============================================================================

model AccountReceivable {
  id              String        @id @default(cuid())
  orderId         String?       @map("order_id")
  clientId        String        @map("client_id")
  description     String?
  amountCents     Int           @map("amount_cents")
  paidAmountCents Int           @default(0) @map("paid_amount_cents")
  dueDate         DateTime      @map("due_date")
  paidDate        DateTime?     @map("paid_date")
  status          PaymentStatus @default(PENDING)
  invoiceId       String?       @map("invoice_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  order   Order?   @relation(fields: [orderId], references: [id])
  client  Client   @relation(fields: [clientId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([clientId, status], name: "idx_ar_client_status")
  @@index([dueDate, status], name: "idx_ar_due_status")
  @@map("accounts_receivable")
}

model AccountPayable {
  id              String        @id @default(cuid())
  supplierId      String?       @map("supplier_id")
  purchaseOrderId String?       @unique @map("purchase_order_id")
  description     String?
  amountCents     Int           @map("amount_cents")
  paidAmountCents Int           @default(0) @map("paid_amount_cents")
  dueDate         DateTime      @map("due_date")
  paidDate        DateTime?     @map("paid_date")
  status          PaymentStatus @default(PENDING)
  categoryId      String?       @map("category_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  supplier      Supplier?          @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  category      FinancialCategory? @relation(fields: [categoryId], references: [id])

  @@index([dueDate, status], name: "idx_ap_due_status")
  @@map("accounts_payable")
}

model FinancialCategory {
  id          String    @id @default(cuid())
  workspaceId String?   @map("workspace_id")
  name        String
  type        String // RECEITA or DESPESA
  parentId    String?   @map("parent_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  workspace       Workspace?          @relation(fields: [workspaceId], references: [id])
  parent          FinancialCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        FinancialCategory[] @relation("CategoryHierarchy")
  accountsPayable AccountPayable[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_financial_categories_ws_deleted")
  @@map("financial_categories")
}

model Invoice {
  id            String           @id @default(cuid())
  invoiceNumber String?          @map("invoice_number")
  direction     InvoiceDirection
  orderId       String?          @map("order_id")
  clientId      String?          @map("client_id")
  companyId     String?          @map("company_id")
  totalCents    Int              @default(0) @map("total_cents")
  issuedAt      DateTime?        @map("issued_at")
  cancelledAt   DateTime?        @map("cancelled_at")
  xmlContent    String?          @map("xml_content")
  pdfUrl        String?          @map("pdf_url")
  accessKey     String?          @map("access_key") // 44 digits
  proFinancasId Int?             @map("pro_financas_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  deletedAt     DateTime?        @map("deleted_at")

  order              Order?              @relation(fields: [orderId], references: [id])
  client             Client?             @relation(fields: [clientId], references: [id])
  company            Company?            @relation(fields: [companyId], references: [id])
  accountsReceivable AccountReceivable[]

  @@map("invoices")
}

model CashRegister {
  id                  String    @id @default(cuid())
  companyId           String    @map("company_id")
  openedByUserId      String    @map("opened_by_user_id")
  closedByUserId      String?   @map("closed_by_user_id")
  openedAt            DateTime  @map("opened_at")
  closedAt            DateTime? @map("closed_at")
  openingBalanceCents Int       @map("opening_balance_cents")
  closingBalanceCents Int?      @map("closing_balance_cents")
  proFinancasId       Int?      @map("pro_financas_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  company  Company @relation(fields: [companyId], references: [id])
  openedBy User    @relation("CashOpenedBy", fields: [openedByUserId], references: [id])
  closedBy User?   @relation("CashClosedBy", fields: [closedByUserId], references: [id])

  @@map("cash_registers")
}

model IdempotencyRecord {
  id         String   @id @default(cuid())
  key        String   @unique
  route      String
  statusCode Int      @map("status_code")
  body       String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([key], name: "idx_idempotency_key")
  @@map("idempotency_records")
}

// ============================================================================
// 1.8 — Production & Separation
// ============================================================================

model ProductionFormula {
  id            String    @id @default(cuid())
  name          String
  yieldQuantity Float     @map("yield_quantity")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  product     Product?
  ingredients ProductionFormulaIngredient[]

  @@map("production_formulas")
}

model ProductionFormulaIngredient {
  id            String    @id @default(cuid())
  formulaId     String    @map("formula_id")
  ingredientId  String    @map("ingredient_id")
  quantity      Float
  unitMeasureId String?   @map("unit_measure_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  formula     ProductionFormula @relation(fields: [formulaId], references: [id])
  ingredient  Product           @relation("FormulaIngredient", fields: [ingredientId], references: [id])
  unitMeasure UnitMeasure?      @relation(fields: [unitMeasureId], references: [id])

  @@map("production_formula_ingredients")
}

model ProductionOrder {
  id             String                @id @default(cuid())
  orderId        String                @map("order_id")
  code           String                @unique
  status         ProductionOrderStatus @default(PENDING)
  type           String? // "SIM" / "NAO"
  machineId      String?               @map("machine_id")
  batch          String?
  scheduledDate  DateTime?             @map("scheduled_date")
  completedDate  DateTime?             @map("completed_date")
  assignedUserId String?               @map("assigned_user_id")
  notes          String?
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  deletedAt      DateTime?             @map("deleted_at")

  order        Order                   @relation(fields: [orderId], references: [id])
  assignedUser User?                   @relation(fields: [assignedUserId], references: [id])
  items        ProductionOrderItem[]
  consumptions ProductionConsumption[]
  outputs      ProductionOutput[]
  losses       ProductionLoss[]

  @@map("production_orders")
}

model ProductionOrderItem {
  id                String    @id @default(cuid())
  productionOrderId String    @map("production_order_id")
  orderItemId       String    @map("order_item_id")
  productId         String    @map("product_id")
  quantity          Float
  pieces            Float?
  size              Float?
  unitMeasureId     String?   @map("unit_measure_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id])
  orderItem       OrderItem       @relation(fields: [orderItemId], references: [id])
  product         Product         @relation(fields: [productId], references: [id])
  unitMeasure     UnitMeasure?    @relation(fields: [unitMeasureId], references: [id])

  @@map("production_order_items")
}

model ProductionConsumption {
  id                String    @id @default(cuid())
  productionOrderId String    @map("production_order_id")
  ingredientId      String    @map("ingredient_id")
  unitMeasureId     String?   @map("unit_measure_id")
  plannedQuantity   Float     @map("planned_quantity")
  actualQuantity    Float?    @map("actual_quantity")
  weightM3          Float?    @map("weight_m3")
  weight            Float?
  costCents         Int?      @map("cost_cents")
  totalCostCents    Int?      @map("total_cost_cents")
  operation         String    @default("S") // S = saida
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id])
  ingredient      Product         @relation(fields: [ingredientId], references: [id])
  unitMeasure     UnitMeasure?    @relation(fields: [unitMeasureId], references: [id])

  @@map("production_consumptions")
}

model ProductionOutput {
  id                String    @id @default(cuid())
  productionOrderId String    @map("production_order_id")
  productId         String    @map("product_id")
  unitMeasureId     String?   @map("unit_measure_id")
  quantity          Float
  operation         String    @default("E") // E = entrada
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id])
  product         Product         @relation(fields: [productId], references: [id])
  unitMeasure     UnitMeasure?    @relation(fields: [unitMeasureId], references: [id])

  @@map("production_outputs")
}

model ProductionLoss {
  id                String    @id @default(cuid())
  productionOrderId String    @map("production_order_id")
  description       String?
  quantity          Float?
  costCents         Int?      @map("cost_cents")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id])

  @@map("production_losses")
}

model SeparationOrder {
  id             String                @id @default(cuid())
  orderId        String                @map("order_id")
  code           String                @unique
  status         SeparationOrderStatus @default(PENDING)
  assignedUserId String?               @map("assigned_user_id")
  scheduledDate  DateTime?             @map("scheduled_date")
  completedDate  DateTime?             @map("completed_date")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  deletedAt      DateTime?             @map("deleted_at")

  order Order                 @relation(fields: [orderId], references: [id])
  items SeparationOrderItem[]

  @@map("separation_orders")
}

model SeparationOrderItem {
  id                String    @id @default(cuid())
  separationOrderId String    @map("separation_order_id")
  orderItemId       String    @map("order_item_id")
  productId         String    @map("product_id")
  quantity          Float
  pieces            Float?
  stockLocation     String?   @map("stock_location")
  isSeparated       Boolean   @default(false) @map("is_separated")
  isChecked         Boolean   @default(false) @map("is_checked")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  separationOrder   SeparationOrder   @relation(fields: [separationOrderId], references: [id])
  orderItem         OrderItem         @relation(fields: [orderItemId], references: [id])
  product           Product           @relation(fields: [productId], references: [id])
  orderItemSupplies OrderItemSupply[]

  @@map("separation_order_items")
}

// ============================================================================
// 1.8b — Stock Requisitions
// ============================================================================

model StockRequisition {
  id                String                 @id @default(cuid())
  code              String                 @unique
  type              StockRequisitionType
  status            StockRequisitionStatus @default(PENDING)
  requestedByUserId String                 @map("requested_by_user_id")
  approvedByUserId  String?                @map("approved_by_user_id")
  orderId           String?                @map("order_id")
  notes             String?
  requestedAt       DateTime               @default(now()) @map("requested_at")
  processedAt       DateTime?              @map("processed_at")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  deletedAt         DateTime?              @map("deleted_at")

  requestedBy User                   @relation("RequisitionRequestedBy", fields: [requestedByUserId], references: [id])
  approvedBy  User?                  @relation("RequisitionApprovedBy", fields: [approvedByUserId], references: [id])
  order       Order?                 @relation(fields: [orderId], references: [id])
  items       StockRequisitionItem[]

  @@map("stock_requisitions")
}

model StockRequisitionItem {
  id                 String    @id @default(cuid())
  requisitionId      String    @map("requisition_id")
  productId          String    @map("product_id")
  requestedQuantity  Float     @map("requested_quantity")
  unitType           String    @map("unit_type") // "UN" or "CX"
  unitsPerBox        Int?      @map("units_per_box")
  quantityInBaseUnit Float     @map("quantity_in_base_unit")
  actualQuantity     Float?    @map("actual_quantity")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  requisition StockRequisition @relation(fields: [requisitionId], references: [id])
  product     Product          @relation(fields: [productId], references: [id])

  @@map("stock_requisition_items")
}

// ============================================================================
// 1.9 — Sync
// ============================================================================

model SyncLog {
  id            String     @id @default(cuid())
  entity        SyncEntity
  status        SyncStatus @default(PENDING)
  totalRecords  Int        @default(0) @map("total_records")
  syncedRecords Int        @default(0) @map("synced_records")
  failedRecords Int        @default(0) @map("failed_records")
  startedAt     DateTime?  @map("started_at")
  completedAt   DateTime?  @map("completed_at")
  errorMessage  String?    @map("error_message")
  metadata      Json?
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@map("sync_logs")
}

model SyncMapping {
  id            String     @id @default(cuid())
  entity        SyncEntity
  proFinancasId Int        @map("pro_financas_id")
  mundialErpId  String     @map("mundial_erp_id")
  lastSyncedAt  DateTime?  @map("last_synced_at")
  checksum      String?
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@unique([entity, proFinancasId])
  @@index([entity, mundialErpId], name: "idx_sync_entity_erp")
  @@map("sync_mappings")
}

// ============================================================================
// 2.12 — Geographic Reference Data (no soft-delete)
// ============================================================================

model State {
  id            String   @id @default(cuid())
  name          String
  uf            String   @unique // 2 chars, e.g. "SP"
  proFinancasId Int?     @map("pro_financas_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  cities City[]

  @@map("states")
}

model City {
  id            String   @id @default(cuid())
  name          String
  stateId       String   @map("state_id")
  ibgeCode      String?  @unique @map("ibge_code")
  proFinancasId Int?     @map("pro_financas_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  state         State          @relation(fields: [stateId], references: [id])
  neighborhoods Neighborhood[]

  @@index([stateId], name: "idx_cities_state")
  @@map("cities")
}

model Neighborhood {
  id            String   @id @default(cuid())
  name          String
  cityId        String   @map("city_id")
  proFinancasId Int?     @map("pro_financas_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  city City @relation(fields: [cityId], references: [id])

  @@index([cityId], name: "idx_neighborhoods_city")
  @@map("neighborhoods")
}

// ============================================================================
// 1.10 — Audit
// ============================================================================

model AuditLog {
  id          String      @id @default(cuid())
  workspaceId String?     @map("workspace_id")
  userId      String?     @map("user_id")
  action      AuditAction
  entity      String
  entityId    String      @map("entity_id")
  changes     Json?
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  createdAt   DateTime    @default(now()) @map("created_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, createdAt], name: "idx_audit_logs_ws_created")
  @@index([entity, entityId], name: "idx_audit_entity")
  @@index([userId, createdAt], name: "idx_audit_user")
  @@map("audit_logs")
}

// ============================================================================
// 1.11 — Chat (Comunicacao Interna)
// ============================================================================

model ChatChannel {
  id              String      @id @default(cuid())
  workspaceId     String      @map("workspace_id")
  name            String?     @db.VarChar(255)
  description     String?     @db.VarChar(1000)
  topic           String?     @db.VarChar(255)
  type            ChannelType @default(PUBLIC)
  participantHash String?     @unique @map("participant_hash")
  locationEntity  String?     @map("location_entity") @db.VarChar(50)
  locationId      String?     @map("location_id")
  createdById     String      @map("created_by_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  workspace Workspace           @relation(fields: [workspaceId], references: [id])
  createdBy User                @relation("ChatChannelCreatedBy", fields: [createdById], references: [id])
  members   ChatChannelMember[]
  messages  ChatMessage[]

  @@index([workspaceId])
  @@index([workspaceId, deletedAt], name: "idx_chat_channels_ws_deleted")
  @@index([type], name: "idx_chat_channels_type")
  @@index([locationEntity, locationId], name: "idx_chat_channels_location")
  @@index([createdById], name: "idx_chat_channels_created_by")
  @@map("chat_channels")
}

model ChatChannelMember {
  id         String            @id @default(cuid())
  channelId  String            @map("channel_id")
  userId     String            @map("user_id")
  role       ChannelMemberRole @default(MEMBER)
  isFollower Boolean           @default(true) @map("is_follower")
  lastReadAt DateTime?         @map("last_read_at")
  closedAt   DateTime?         @map("closed_at")
  leftAt     DateTime?         @map("left_at")
  createdAt  DateTime          @default(now()) @map("created_at")

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@unique([channelId, userId], name: "uq_channel_member")
  @@index([userId], name: "idx_chat_channel_members_user")
  @@index([userId, isFollower], name: "idx_chat_channel_members_follower")
  @@map("chat_channel_members")
}

model ChatMessage {
  id              String          @id @default(cuid())
  channelId       String          @map("channel_id")
  authorId        String          @map("author_id")
  parentMessageId String?         @map("parent_message_id")
  type            ChatMessageType @default(MESSAGE)
  content         String          @db.Text
  contentFormat   ContentFormat   @default(TEXT_MD) @map("content_format")
  richContent     Json?           @map("rich_content")
  assigneeId      String?         @map("assignee_id")
  resolved        Boolean         @default(false)
  postData        Json?           @map("post_data")
  editedAt        DateTime?       @map("edited_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  channel       ChatChannel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author        User                  @relation("ChatMessageAuthor", fields: [authorId], references: [id])
  parentMessage ChatMessage?          @relation("MessageReplies", fields: [parentMessageId], references: [id])
  replies       ChatMessage[]         @relation("MessageReplies")
  assignee      User?                 @relation("ChatMessageAssignee", fields: [assigneeId], references: [id])
  reactions     ChatReaction[]
  mentions      ChatMention[]
  followers     ChatMessageFollower[]

  @@index([channelId, createdAt], name: "idx_chat_messages_channel_time")
  @@index([parentMessageId], name: "idx_chat_messages_parent")
  @@index([authorId], name: "idx_chat_messages_author")
  @@index([assigneeId], name: "idx_chat_messages_assignee")
  @@map("chat_messages")
}

model ChatMessageFollower {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@unique([messageId, userId], name: "uq_message_follower")
  @@index([userId], name: "idx_chat_message_followers_user")
  @@map("chat_message_followers")
}

model ChatReaction {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emojiName String   @map("emoji_name") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emojiName], name: "uq_reaction")
  @@index([messageId], name: "idx_chat_reactions_message")
  @@map("chat_reactions")
}

model ChatMention {
  id              String   @id @default(cuid())
  messageId       String   @map("message_id")
  mentionedUserId String   @map("mentioned_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  message       ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mentionedUser User        @relation(fields: [mentionedUserId], references: [id])

  @@unique([messageId, mentionedUserId], name: "uq_mention")
  @@index([mentionedUserId], name: "idx_chat_mentions_user")
  @@map("chat_mentions")
}

// ============================================================================
// 1.12 — Notifications
// ============================================================================

model Notification {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  userId       String               @map("user_id")
  user         User                 @relation(fields: [userId], references: [id])
  type         NotificationType
  category     NotificationCategory
  title        String
  description  String
  entityId     String?              @map("entity_id")
  entityUrl    String?              @map("entity_url")
  status       NotificationStatus   @default(UNREAD)
  snoozedUntil DateTime?            @map("snoozed_until")
  readAt       DateTime?            @map("read_at")
  clearedAt    DateTime?            @map("cleared_at")

  @@index([userId, status, createdAt], name: "idx_notifications_user_status_created")
  @@index([userId, category, status], name: "idx_notifications_user_category_status")
  @@index([userId, status], name: "idx_notifications_user_status")
  @@index([snoozedUntil], name: "idx_notifications_snoozed_until")
  @@map("notifications")
}

// ============================================================================
// 1.13 — Workspaces (Multi-tenancy Root)
// ============================================================================

model Workspace {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  logoUrl   String?       @map("logo_url")
  color     String?
  plan      WorkspacePlan @default(FREE)
  ownerId   String        @map("owner_id")
  /// Bag de configuracoes livres por workspace (Json). Feature flags
  /// per-workspace vivem aqui sob chaves especificas (ex.: `tasksV2Enabled`).
  /// Migration de policies (Sprint 8) adiciona a coluna como JSONB not null
  /// default '{}'. Evoluir com cautela — nao usar para dados operacionais.
  settings  Json          @default("{}")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  owner                  User                      @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members                WorkspaceMember[]
  invites                WorkspaceInvite[]
  lastAccessedByUsers    User[]                    @relation("LastAccessedWorkspace")
  spaces                 Space[]
  clients                Client[]
  orders                 Order[]
  products               Product[]
  suppliers              Supplier[]
  companies              Company[]
  dashboards             Dashboard[]
  chatChannels           ChatChannel[]
  auditLogs              AuditLog[]
  carriers               Carrier[]
  paymentMethods         PaymentMethod[]
  clientClassifications  ClientClassification[]
  deliveryRoutes         DeliveryRoute[]
  orderTypes             OrderType[]
  orderFlows             OrderFlow[]
  orderModels            OrderModel[]
  productTypes           ProductType[]
  brands                 Brand[]
  productDepartments     ProductDepartment[]
  unitMeasures           UnitMeasure[]
  financialCategories    FinancialCategory[]
  statusTemplates        StatusTemplate[]
  priceTables            PriceTable[]
  customTaskTypes        CustomTaskType[]
  workItemTags           WorkItemTag[]
  workItemTemplates      WorkItemTemplate[]
  customFieldDefinitions CustomFieldDefinition[]
  customFieldGroups      CustomFieldGroup[]
  automations            Automation[]
  kommoAccount           KommoAccount?
  favorites              Favorite[]
  channelOrganizations   UserChannelOrganization[]

  @@index([deletedAt], name: "idx_workspaces_deleted")
  @@map("workspaces")
}

model Automation {
  id              String              @id @default(cuid())
  workspaceId     String              @map("workspace_id")
  createdById     String              @map("created_by_id")
  name            String
  description     String?
  trigger         AutomationTrigger
  scopeType       AutomationScopeType @map("scope_type")
  scopeId         String?             @map("scope_id")
  compiledActions Json                @map("compiled_actions")
  conditions      Json                @default("[]")
  isActive        Boolean             @default(true) @map("is_active")
  executionCount  Int                 @default(0) @map("execution_count")
  lastExecutedAt  DateTime?           @map("last_executed_at")
  cronExpression  String?             @map("cron_expression")
  timezone        String?
  nextRunAt       DateTime?           @map("next_run_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  deletedAt       DateTime?           @map("deleted_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("AutomationCreator", fields: [createdById], references: [id])

  @@index([workspaceId, isActive, trigger], name: "idx_automations_ws_active_trigger")
  @@index([workspaceId, scopeType, scopeId], name: "idx_automations_ws_scope")
  @@index([nextRunAt], name: "idx_automations_next_run")
  @@map("automations")
}

model WorkspaceMember {
  id           String              @id @default(cuid())
  workspaceId  String              @map("workspace_id")
  userId       String              @map("user_id")
  role         WorkspaceMemberRole @default(MEMBER)
  sidebarOrder Json                @default("{}") @map("sidebar_order")
  joinedAt     DateTime            @default(now()) @map("joined_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([workspaceId, userId])
  @@index([userId], name: "idx_ws_members_user")
  @@index([workspaceId, role], name: "idx_ws_members_ws_role")
  @@map("workspace_members")
}

model WorkspaceInvite {
  id          String              @id @default(cuid())
  workspaceId String              @map("workspace_id")
  email       String
  role        WorkspaceMemberRole @default(MEMBER)
  token       String              @unique
  status      InviteStatus        @default(PENDING)
  expiresAt   DateTime            @map("expires_at")
  invitedById String              @map("invited_by_id")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  invitedBy User      @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([email, workspaceId], name: "idx_ws_invites_email_ws")
  @@map("workspace_invites")
}

// ============================================================================
// Kommo integration — Sprint 1 (migration `kommo_foundations_1`)
// ----------------------------------------------------------------------------
// PLANO-KOMMO-DASHBOARD §5.2 — 4 dos 11 models prioritarios.
// Os 7 restantes (KommoPipeline, KommoStatus, KommoDepartment, KommoAgent,
// KommoLead, KommoSyncCheckpoint, KommoMetricSnapshot) chegam em Sprint 2
// via migration `kommo_foundations_2`. Campos FK nullable que apontam para
// esses models (leadId, responsibleAgentId, departmentId, authorAgentId)
// ja existem como colunas String sem @relation; as @relation serao
// adicionadas na migration seguinte, sem mexer na coluna.
// ============================================================================

model KommoAccount {
  id                String             @id @default(cuid())
  workspaceId       String             @unique @map("workspace_id")
  subdomain         String
  authType          KommoAuthType      @map("auth_type")
  accessToken       String             @map("access_token") // ENCRYPTED (envelope — ADR-006 pending)
  refreshToken      String?            @map("refresh_token") // ENCRYPTED (envelope — ADR-006 pending); nullable p/ long-lived token
  expiresAt         DateTime?          @map("expires_at")
  hmacSecret        String             @map("hmac_secret") // ENCRYPTED (envelope — ADR-006 pending)
  status            KommoAccountStatus @default(ACTIVE)
  lastSyncAt        DateTime?          @map("last_sync_at")
  connectedByUserId String?            @map("connected_by_user_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")

  workspace     Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations KommoConversation[]
  messages      KommoMessage[]
  pipelines     KommoPipeline[]
  agents        KommoAgent[]
  departments   KommoDepartment[]
  leads         KommoLead[]

  @@map("kommo_accounts")
}

model KommoConversation {
  id                 String                  @id @default(cuid())
  workspaceId        String                  @map("workspace_id")
  accountId          String                  @map("account_id")
  kommoChatId        BigInt                  @map("kommo_chat_id")
  leadId             String?                 @map("lead_id") // FK -> KommoLead (Sprint 2)
  responsibleAgentId String?                 @map("responsible_agent_id") // FK -> KommoAgent (Sprint 2)
  departmentId       String?                 @map("department_id") // FK -> KommoDepartment (Sprint 2)
  status             KommoConversationStatus @default(OPEN)
  firstMessageAt     DateTime?               @map("first_message_at")
  firstResponseAt    DateTime?               @map("first_response_at")
  resolvedAt         DateTime?               @map("resolved_at")
  lastMessageAt      DateTime?               @map("last_message_at")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")
  deletedAt          DateTime?               @map("deleted_at")

  account          KommoAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lead             KommoLead?       @relation(fields: [leadId], references: [id])
  responsibleAgent KommoAgent?      @relation("ConversationResponsible", fields: [responsibleAgentId], references: [id])
  department       KommoDepartment? @relation("ConversationDepartment", fields: [departmentId], references: [id])
  messages         KommoMessage[]

  @@unique([workspaceId, kommoChatId])
  @@index([workspaceId, status])
  @@index([workspaceId, responsibleAgentId])
  @@index([workspaceId, resolvedAt])
  @@index([workspaceId, createdAt])
  @@map("kommo_conversations")
}

model KommoMessage {
  id             String                @id @default(cuid())
  workspaceId    String                @map("workspace_id")
  accountId      String                @map("account_id")
  conversationId String                @map("conversation_id")
  kommoMessageId String                @map("kommo_message_id")
  direction      KommoMessageDirection
  authorAgentId  String?               @map("author_agent_id") // FK -> KommoAgent (Sprint 2)
  contentPreview String                @map("content_preview") // truncado a 200 chars (squad-kommo principio #9)
  contentHash    String                @map("content_hash") // SHA-256 do conteudo full
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  deletedAt      DateTime?             @map("deleted_at")

  account      KommoAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  conversation KommoConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorAgent  KommoAgent?       @relation("MessageAuthor", fields: [authorAgentId], references: [id])

  @@unique([workspaceId, kommoMessageId])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([conversationId, createdAt])
  @@index([workspaceId, direction, createdAt]) // "Horarios de Pico"
  @@index([workspaceId, authorAgentId, createdAt]) // "Performance por Atendente"
  @@map("kommo_messages")
}

// Operacional — hard delete via purge cron (>30 dias). NAO carrega deletedAt.
model KommoWebhookEvent {
  id           String                  @id @default(cuid())
  workspaceId  String                  @map("workspace_id")
  eventId      String                  @map("event_id")
  eventType    String                  @map("event_type")
  payloadHash  String                  @map("payload_hash") // SHA-256
  signature    String
  status       KommoWebhookEventStatus @default(RECEIVED)
  receivedAt   DateTime                @default(now()) @map("received_at")
  processedAt  DateTime?               @map("processed_at")
  errorMessage String?                 @map("error_message")
  retryCount   Int                     @default(0) @map("retry_count")

  @@unique([workspaceId, eventId])
  @@index([workspaceId, status, receivedAt])
  @@index([workspaceId, eventType, receivedAt])
  @@map("kommo_webhook_events")
}

// ============================================================================
// Kommo integration — Sprint 2 (migration `kommo_foundations_2`)
// ----------------------------------------------------------------------------
// PLANO-KOMMO-DASHBOARD §5.2 — os 7 models restantes (5 dominio + 2
// operacionais) completando a base Prisma da integracao Kommo.
//
// Dominio (carregam `deletedAt` — soft delete):
//   - KommoPipeline       (pipeline de vendas)
//   - KommoStatus         (etapa dentro de pipeline)
//   - KommoDepartment     (grupo/departamento Kommo)
//   - KommoAgent          (usuario Kommo → mapeamento opcional User ERP)
//   - KommoLead           (oportunidade/negocio)
//
// Operacionais (hard delete via purge cron — sem `deletedAt`):
//   - KommoSyncCheckpoint (cursor de backfill/reconciliacao)
//   - KommoMetricSnapshot (pre-agregado ADR-009)
//
// Migration: aditiva-only. Alem das 7 CREATE TABLEs, a migration adiciona 4
// FKs em kommo_conversations/kommo_messages (leadId, responsibleAgentId,
// departmentId, authorAgentId) — todas ja existem como coluna NULL; apenas a
// constraint FK e criada agora que o target existe.
// ============================================================================

model KommoPipeline {
  id              String    @id @default(cuid())
  workspaceId     String    @map("workspace_id")
  accountId       String    @map("account_id")
  kommoPipelineId BigInt    @map("kommo_pipeline_id")
  name            String
  sortOrder       Int       @default(0) @map("sort_order")
  isArchived      Boolean   @default(false) @map("is_archived")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  account  KommoAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  statuses KommoStatus[]
  leads    KommoLead[]

  @@unique([workspaceId, kommoPipelineId])
  @@index([workspaceId, isArchived])
  @@map("kommo_pipelines")
}

model KommoStatus {
  id            String    @id @default(cuid())
  workspaceId   String    @map("workspace_id")
  pipelineId    String    @map("pipeline_id")
  kommoStatusId BigInt    @map("kommo_status_id")
  name          String
  color         String?
  sortOrder     Int       @default(0) @map("sort_order")
  isTerminal    Boolean   @default(false) @map("is_terminal")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  pipeline KommoPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads    KommoLead[]

  @@unique([workspaceId, pipelineId, kommoStatusId])
  @@index([workspaceId, pipelineId])
  @@map("kommo_statuses")
}

model KommoDepartment {
  id                String    @id @default(cuid())
  workspaceId       String    @map("workspace_id")
  accountId         String    @map("account_id")
  kommoDepartmentId BigInt    @map("kommo_department_id")
  name              String
  isArchived        Boolean   @default(false) @map("is_archived")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  account       KommoAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  agents        KommoAgent[]
  conversations KommoConversation[] @relation("ConversationDepartment")

  @@unique([workspaceId, kommoDepartmentId])
  @@map("kommo_departments")
}

model KommoAgent {
  id           String    @id @default(cuid())
  workspaceId  String    @map("workspace_id")
  accountId    String    @map("account_id")
  kommoUserId  BigInt    @map("kommo_user_id")
  name         String
  email        String?
  departmentId String?   @map("department_id")
  mappedUserId String?   @map("mapped_user_id")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  account                  KommoAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  department               KommoDepartment?    @relation(fields: [departmentId], references: [id])
  mappedUser               User?               @relation("KommoAgentMappedUser", fields: [mappedUserId], references: [id])
  leadsResponsible         KommoLead[]         @relation("LeadResponsible")
  conversationsResponsible KommoConversation[] @relation("ConversationResponsible")
  messagesAuthored         KommoMessage[]      @relation("MessageAuthor")

  @@unique([workspaceId, kommoUserId])
  @@index([workspaceId, isActive])
  @@index([workspaceId, departmentId])
  @@map("kommo_agents")
}

model KommoLead {
  id                 String    @id @default(cuid())
  workspaceId        String    @map("workspace_id")
  accountId          String    @map("account_id")
  kommoLeadId        BigInt    @map("kommo_lead_id")
  pipelineId         String    @map("pipeline_id")
  statusId           String    @map("status_id")
  responsibleAgentId String?   @map("responsible_agent_id")
  name               String?
  valueCents         BigInt?   @map("value_cents")
  closedAt           DateTime? @map("closed_at")
  isClosed           Boolean   @default(false) @map("is_closed")
  isWon              Boolean?  @map("is_won")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  account          KommoAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  pipeline         KommoPipeline       @relation(fields: [pipelineId], references: [id])
  status           KommoStatus         @relation(fields: [statusId], references: [id])
  responsibleAgent KommoAgent?         @relation("LeadResponsible", fields: [responsibleAgentId], references: [id])
  conversations    KommoConversation[]

  @@unique([workspaceId, kommoLeadId])
  @@index([workspaceId, pipelineId, statusId])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, responsibleAgentId])
